%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-bill
    Cash Management
  %li.breadcrumb-item
    = link_to equity_withdrawal_collections_path do
      .fa.fa-download
      Equity Withdrawals
  %li.breadcrumb-item
    Equity Withdrawal: #{@equity_withdrawal_collection.id}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      / = link_to "#", class: 'btn', id: 'btn-print' do
      /   .fa.fa-print
      /   Print
      - if @equity_withdrawal_collection.pending? && (current_user.roles.include?("MIS") || current_user.roles.include?("BK") || current_user.roles.include?("SBK"))
        = link_to equity_withdrawal_collection_path(@equity_withdrawal_collection), class: 'btn', method: :delete, data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
        = link_to "#", class: 'btn', id: 'btn-approve' do
          .fa.fa-check
          Approve
