%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-bill
    Cash Management
  %li.breadcrumb-item
    = link_to insurance_fund_transfer_collections_path do
      .fa.fa-download
      Insurance Fund Transfers
  %li.breadcrumb-item
    Insurance Fund Transfer: #{@insurance_fund_transfer_collection.id}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to "#", class: 'btn', id: 'btn-print' do
        .fa.fa-print
        Print
      - if @insurance_fund_transfer_collection.pending? && (current_user.roles.include?("MIS") || current_user.roles.include?("BK") || current_user.roles.include?("SBK") || current_user.roles.include?("REMOTE-BK") || current_user.roles.include?("REMOTE-FM"))
        = link_to insurance_fund_transfer_collection_path(@insurance_fund_transfer_collection), class: 'btn', method: :delete, data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
      - if @insurance_fund_transfer_collection.pending? && !@insurance_fund_transfer_collection.finalized? && (current_user.roles.include?("REMOTE-BK") || current_user.roles.include?("MIS") || current_user.roles.include?("REMOTE-FM"))
        = link_to "#", class: 'btn', id: 'btn-finalize' do
          .fa.fa-check
          Finalize
      - if @insurance_fund_transfer_collection.pending? && (current_user.roles.include?("MIS") || current_user.roles.include?("BK") || current_user.roles.include?("SBK"))    
        - if Settings.activate_microinsurance
          - if @insurance_fund_transfer_collection.finalized?
            = link_to "#", class: 'btn', id: 'btn-approve' do
              .fa.fa-check
              Approve  
        - else
          = link_to "#", class: 'btn', id: 'btn-approve' do
            .fa.fa-check
            Approve
