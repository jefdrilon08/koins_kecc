= title @insurance_fund_transfer_collection.id
.row
  .col
    .card
      .card-body
        - if @insurance_fund_transfer_collection.pending?
          .alert.alert-info
            %p
              Pindutin ang amount upang baguhin ito.
        %h5
          Insurance Fund Transfer Collection for #{@insurance_fund_transfer_collection.branch} / #{@insurance_fund_transfer_collection.center} - #{@insurance_fund_transfer_collection.collection_date.strftime("%b %d, %Y")}
        #react-root

        - if debug?
          %pre
            %code
              #{JSON.pretty_generate(JSON.parse(@insurance_fund_transfer_collection.to_json))}

= render partial: "shared/modals/print"
= render partial: "insurance_fund_transfer_collections/modals/approve"
= render partial: "insurance_fund_transfer_collections/modals/finalize"
= render partial: "insurance_fund_transfer_collections/modals/revert"
= render partial: "templates/error_list"
