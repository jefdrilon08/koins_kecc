= form_tag "", method: 'GET' do
  .row
    .col-md-2
      .form-group
        %label
          Reference Number
        = text_field_tag :reference_number, params[:reference_number], class: 'form-control'
    .col-md-2
      .form-group
        %label
          Start Date
        = text_field_tag :start_date, params[:start_date], class: 'form-control', type: :date
    .col-md-2
      .form-group
        %label
          End Date
        = text_field_tag :end_date, params[:end_date], class: 'form-control', type: :date
    .col-md-2
      .form-group
        %label
          Branch
        = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "branch-select", prompt: "-- SELECT --"
    .col-md-2
      .form-group
        %label
          Status
        = select_tag :status, options_for_select(MembershipPaymentCollection::STATUSES, @status), class: "form-control select-select2", id: "status-select", prompt: "-- SELECT --"
    .col-md-2
      .form-group
        %label
          Actions
        = button_tag type: 'submit', class: 'btn btn-info btn-block' do
          .bi.bi-search
