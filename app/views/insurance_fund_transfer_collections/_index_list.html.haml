%table.table.table-sm.table-hover.table-bordered
  %thead
    %tr
      - if microinsurance?
        %th
          Date Created
        %th
          Date Approved
      %th
        Collection Date
      %th
        Branch
      %th.text-right
        Amount Collected
      %th
        %center
          Status
      - if microinsurance?
        %th
          %center
            Finalize Stat
  %tbody
    - @insurance_fund_transfer_collections.each do |o|
      %tr
        - if microinsurance?
          %td
            = link_to insurance_fund_transfer_collection_path(o) do
              %strong
                #{o.created_at.strftime("%b %d, %Y")}
          - if !o.date_approved.nil?
            %td
              = link_to insurance_fund_transfer_collection_path(o) do
                %strong
                  #{o.date_approved.strftime("%b %d, %Y")}
          - else
            %td
              =nil
        %td
          = link_to insurance_fund_transfer_collection_path(o) do
            %strong
              #{o.collection_date.strftime("%b %d, %Y")}
        %td
          #{o.branch}
        %td.text-right
          %strong
            #{number_to_currency(o.total_collected, unit: "")}
        %td
          %center
            - if o.pending?
              .badge.badge-danger
                Pending
            - elsif o.approved?
              .badge.badge-success
                Approved
        - if microinsurance?
          %td
            %center
              - if o.pending? && o.finalized?
                .badge.badge-primary
                  For Approval
              - elsif o.pending? && !o.finalized?
                .badge.badge-warning
                  For Finalize
              - elsif o.approved?
                .badge.badge-success
                  Approved
