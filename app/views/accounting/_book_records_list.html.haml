%table.table.table-sm.table-hover
  %thead
    %tr
      %th
        Status
      %th{ width: "10%" }
        Book
      - if microinsurance?
        %th
          Sub Ref Number
        %th
          Accounting Fund
      - else
        %th
          Ref Number
      - if book == "CDB"  
        %th
          Check Number
        %th
          Check Voucher Number
      - if book == "CRB"  
        %th
          OR Number
        - if microinsurance?
          %th
            AR Number
      %th
        Date Prepared
      %th
        Date Posted  
      %th.text-right
        Amount
  %tbody
    - records.each do |o|
      %tr
        %td.text-muted
          = link_to accounting_accounting_entry_path(o) do
            #{o.status.upcase}
        %td.text-muted
          = link_to accounting_accounting_entry_path(o) do
            %strong
              %small
                #{o.book}
        - if microinsurance?  
          %td.text-muted
            = link_to accounting_accounting_entry_path(o) do
              %strong
                %small
                  #{o.data.with_indifferent_access[:sub_reference_number]}
          %td.text-muted
            = link_to accounting_accounting_entry_path(o) do
              %strong
                %small
                  #{o.accounting_fund}
        - else
          %td.text-muted
            = link_to accounting_accounting_entry_path(o) do
              %strong
                %small
                  #{o.reference_number}
        - if book == "CDB"  
          %td.text-muted
            = link_to accounting_accounting_entry_path(o) do
              %strong
                %small
                  #{o.data.with_indifferent_access[:check_number]}
          %td.text-muted
            = link_to accounting_accounting_entry_path(o) do
              %strong
                %small
                  #{o.data.with_indifferent_access[:check_voucher_number]}
        - if book == "CRB"  
          %td.text-muted
            = link_to accounting_accounting_entry_path(o) do
              %strong
                %small
                  #{o.data.with_indifferent_access[:or_number]}
          - if microinsurance?
            %td.text-muted
              = link_to accounting_accounting_entry_path(o) do
                %strong
                  %small
                    #{o.data.with_indifferent_access[:ar_number]}
        %td.text-muted
          = link_to accounting_accounting_entry_path(o) do
            %strong
              %small
                #{o.date_prepared.strftime("%B %d, %Y")}
        %td.text-muted
          = link_to accounting_accounting_entry_path(o) do
            %strong
              %small
                #{o.date_posted.try(:strftime, "%B %d, %Y")}        
        %td.text-right
          = link_to accounting_accounting_entry_path(o) do
            %strong
              %small
                #{number_to_currency(o.total_debit, unit: "")}