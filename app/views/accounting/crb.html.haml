= title
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            = render partial: "filter"
            - if microinsurance?
              = render partial: "book_records_list", locals: { records: @records, book: "CRB" }
            - else
              = render partial: "book_records", locals: { records: @records }
            = paginate @records

= render partial: "shared/modals/print"
