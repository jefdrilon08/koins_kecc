%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-book-reader
    Books
  %li.breadcrumb-item
    = link_to "/accounting/books/#{@accounting_entry.book.downcase}" do
      .fa.fa-book
      #{@accounting_entry.book}
  %li.breadcrumb-item
    .fa.fa-file
    - if @accounting_entry.pending?
      [PENDING]
    - else
      #{@accounting_entry.reference_number} - #{@accounting_entry.book}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      - if @accounting_entry.pending?
        #btn-approve.btn{ data: { id: @accounting_entry.id } }
          .fa.fa-check
          Approve
