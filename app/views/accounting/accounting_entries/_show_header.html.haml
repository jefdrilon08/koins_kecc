%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-book-reader
    Books
  %li.breadcrumb-item
    = link_to "/accounting/books/#{@accounting_entry.book.downcase}" do
      .fa.fa-book
      #{@accounting_entry.book}
  %li.breadcrumb-item
    .fa.fa-file
    - if @accounting_entry.pending?
      [PENDING]
    - else
      #{@accounting_entry.reference_number} - #{@accounting_entry.book}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      #btn-print.btn{ data: { id: @accounting_entry.id } }
        .fa.fa-print
        Print
      - if @accounting_entry.pending?
        = link_to accounting_accounting_entry_form_path(id: @accounting_entry.id, book: @accounting_entry.book, accounting_fund_id: @accounting_entry.accounting_fund_id), class: 'btn' do
          .fa.fa-pencil-alt
          Edit
        = link_to accounting_delete_accounting_entry_path(@accounting_entry.id), class: 'btn', method: :delete, data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
        - case @accounting_entry.book
          - when "JVB"
            - if sbk_mis_user
              #btn-approve.btn{ data: { id: @accounting_entry.id } }
                .fa.fa-check
                Approve
          - else
            - if sbk_bk_mis_user
              #btn-approve.btn{ data: { id: @accounting_entry.id } }
                .fa.fa-check
                Approve
