= render partial: "show_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          = render partial: "shared/accounting_entry", locals: { accounting_entry: @accounting_entry }

= render partial: "modal_approve"
= render partial: "modal_print"
= render partial: "templates/error_list"

= javascript_include_tag "accounting/accounting_entries/Show.js"

:javascript
  $(document).ready(function() {
    var authenticityToken = $("meta[name='csrf-token']").attr('content');

    Show.init({
      authenticityToken: authenticityToken
    });
  });
