= title @accounting_entry.id
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            = render partial: "shared/accounting_entry", locals: { accounting_entry: @accounting_entry }
            - if @accounting_entry.approved?
              = render partial: "accounting/accounting_entries/adjustment_actions", locals: { accounting_entry: @accounting_entry }

            - if @activity_logs.any?
              %hr
              = render partial: "accounting/accounting_entries/activity_logs", locals: { activity_logs: @activity_logs }

= render partial: "modal_approve"
= render partial: "modal_print"
= render partial: "modal_adjust_date_posted"
= render partial: "templates/error_list"
