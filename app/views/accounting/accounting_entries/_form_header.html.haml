%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-book-reader
    Books
  %li.breadcrumb-item
    = link_to "/accounting/books/#{params[:book].upcase}" do
      .fa.fa-book
      #{params[:book].downcase}
  %li.breadcrumb-item
    .fa.fa-file
    Accounting Entry Form
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to accounting_accounting_entry_form_path(book: params[:book], branch_id: params[:branch_id], reference_number: params[:reference_number]), class: "btn" do
        .fa.fa-plus
        New Entry
