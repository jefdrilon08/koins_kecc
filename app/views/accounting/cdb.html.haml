= render partial: "books_header", locals: { book: "CDB", book_title: "Cash Disbursements" }

.container-fluid
  .row
    .col
      .card
        .card-body
          = render partial: "filter"  
          - if microinsurance?
            = render partial: "book_records_list", locals: { records: @records, book: "CDB" }
          - else
            = render partial: "book_records", locals: { records: @records }
          = paginate @records

#parameters{ data: { book: "CDB" } }
= render partial: "shared/modals/print"
= javascript_include_tag "accounting/BooksIndex"

:javascript
  $(document).ready(function() {
    var $parameters       = $("#parameters");
    var book              = $parameters.data("book");
    var authenticityToken = $("meta[name='csrf-token']").attr('content');

    BooksIndex.init({
      book: book,
      authenticityToken: authenticityToken
    });
  });
