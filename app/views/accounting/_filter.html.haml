= form_tag "", method: 'GET' do
  .row
    .col-md-3
      .form-group
        %label
          Query
        = text_field_tag :q, params[:q], class: "form-control", placeholder: "Reference # / Particular / Payee / OR"
    .col-md-2
      .form-group
        %label
          Start Date
        = date_field_tag :start_date, @start_date, class: "form-control", placeholder: "yyyy-mm-dd", id: "input-start-date"
    .col-md-2
      .form-group
        %label
          End Date
        = date_field_tag :end_date, @end_date, class: "form-control", placeholder: "yyyy-mm-dd", id: "input-end-date"
    .col-md-2
      .form-group
        %label
          Branch
        = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch_id), class: "form-control select-select2", id: "select-branch"
    .col-md-2
      .form-group
        %label
          Status
        = select_tag :status, options_for_select(@statuses, @status), class: "form-control select-select2", id: "branch-select", prompt: "-- SELECT --"
    .col-md-1
      .form-group
        %label
          Actions
        .btn-group
          = button_tag type: 'submit', class: 'btn btn-info btn-block btn-sm' do
            .fa.fa-search
          #btn-print.btn.btn-warning
            .fa.fa-print
