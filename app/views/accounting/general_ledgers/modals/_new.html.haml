#modal-new.modal.fade
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          General Ledger
      .modal-body
        .modal-body-content
          .row
            .col-md-6.col-xs-12
              .form-group
                %label
                  Start Date
                = date_field_tag :start_date, @start_date, class: "form-control", id: "input-start-date"
            .col-md-6.col-xs-12
              .form-group
                %label
                  End Date
                = date_field_tag :end_date, @end_date, class: "form-control", id: "input-end-date"
          .row
            .col
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "select-branch"
          .row
            .col
              .form-group
                %label
                  Accounting Fund
                = select_tag :accounting_fund_id, options_from_collection_for_select(@accounting_funds, :id, :name, @accounting_fund.try(:id)), class: "form-control select-select2", id: "select-accounting-fund", prompt: "-- SELECT --"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
