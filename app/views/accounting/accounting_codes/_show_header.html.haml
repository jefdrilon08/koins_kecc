%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-file
    Accounting
  %li.breadcrumb-item
    = link_to accounting_accounting_codes_path do
      .fa.fa-file
      Chart of Accounts
  %li.breadcrumb-item
    .fa.fa-accounting_code
    Accounting Code: #{@accounting_code}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to edit_accounting_accounting_code_path(@accounting_code), class: 'btn' do
        .fa.fa-pencil-alt
        Edit
      = link_to accounting_accounting_code_path(@accounting_code), method: :delete, class: 'btn', data: { confirm: "Are you sure?" } do
        .fa.fa-times
        Delete
