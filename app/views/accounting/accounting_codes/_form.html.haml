= simple_form_for([:accounting, @accounting_code]) do |f|
  .row
    .col
      .form-group
        = f.input :code, input_html: { class: 'form-control', disabled: !is_mis_user? }
    .col
      .form-group
        = f.input :name, input_html: { class: 'form-control', disabled: !is_mis_user? }
    .col
      .form-group
        = f.input :category, as: :select, collection: AccountingCode::CATEGORIES, input_html: { class: 'form-control', disabled: !is_mis_user? }
  %hr
  .btn-group
    - if is_mis_user?
      %button{ type: "submit", class: "btn btn-primary" }
        .fa.fa-check
        Save
    = link_to(is_mis_user? ? accounting_accounting_code_path(@accounting_code) : accounting_accounting_codes_path, class: 'btn btn-danger') do
      .fa.fa-times
      Cancel
