= simple_form_for([:accounting, @accounting_code]) do |f|
  .row
    .col
      .form-group
        = f.input :code, input_html: { class: 'form-control' }
    .col
      .form-group
        = f.input :name, input_html: { class: 'form-control' }
    .col
      .form-group
        = f.input :category, as: :select, collection: AccountingCode::CATEGORIES, input_html: { class: 'form-control' }
  %hr
  .btn-group
    %button{ type: "submit", class: "btn btn-primary" }
      .fa.fa-check
      Save
    - if @accounting_code.new_record?
      = link_to accounting_accounting_codes_path, class: 'btn btn-danger' do
        .fa.fa-times
        Cancel
    - else
      = link_to accounting_accounting_code_path(@accounting_code), class: 'btn btn-danger' do
        .fa.fa-times
        Cancel
