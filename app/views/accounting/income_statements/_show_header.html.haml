%ol.breadcrumb
  %li.breadcrumb-item
    = link_to accounting_income_statements_path do
      .fa.fa-book
      Income Statements
  %li.breadcrumb-item
    .fa.fa-book
    #{@meta["branch_name"]} #{@meta["year"]}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      - if !@income_statement.processing?
        = link_to accounting_income_statement_path(@income_statement), method: :delete, class: "btn", data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
