#modal-new.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Generate Income Statement
      .modal-body
        .modal-body-content
          .row
            .col
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "select-branch"
            .col
              .form-group
                %label
                  Month
                = select_month Date.today, {}, class: "form-control", id: "select-month"
            .col
              .form-group
                %label
                  Year
                = select_tag :year, options_for_select([Date.today.year, Date.today.year - 1], Date.today.year), class: "form-control", id: "select-year"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
