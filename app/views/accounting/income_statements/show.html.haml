= title @income_statement.id
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            - if @income_statement.error?
              = render partial: "data_stores/error_page"
            - elsif @income_statement.processing?
              %p
                Still processing...
            - elsif @income_statement.done?
              = render partial: "show_details"
