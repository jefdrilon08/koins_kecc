%ol.breadcrumb
  %li.breadcrumb-item
    = link_to accounting_balance_sheets_path do
      .fa.fa-book
      Balance Sheets
  %li.breadcrumb-item
    .fa.fa-book
    #{@meta["branch_name"]} #{@meta["year"]}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      - if !@balance_sheet.processing?
        = link_to accounting_balance_sheet_path(@balance_sheet), method: :delete, class: "btn", data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
