= title @record.id
= render partial: "show_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          - if @record.error?
            = render partial: "data_stores/error_page"
          - else
            = render partial: "accounting/year_end_closings/data"

#parameters{ data: { id: "#{@record.id}" } }

= render partial: "accounting/year_end_closings/modals/approve"
= render partial: "templates/error_list"

= javascript_include_tag "accounting/year_end_closings/Show"

:javascript
  $(document).ready(function() {
    var $parameters       = $("#parameters");
    var authenticityToken = $("meta[name='csrf-token']").attr('content');
    var id                = $parameters.data("id");

    Show.init({
      authenticityToken: authenticityToken,
      id: id
    });
  });
