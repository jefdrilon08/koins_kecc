%table.table.table-bordered.table-sm.table-hover
  %thead
    %tr
      %th.text-center
        Closing Date
      %th
        Branch
      %th.text-center
        Status
      %th.text-center
        Started
      %th.text-center
        Last Updated
  %thead
    - @records.each do |o|
      - closed_on = o.meta["closing_date"].to_date.strftime("%b %d, %Y")
      %tr
        %td.text-center
          %strong
            - if o.processing?
              = closed_on
            - else
              = link_to closed_on, accounting_year_end_closing_path(o)
        %td= o.meta["branch_name"]
        %td.text-center
          - if o.processing?
            .badge.badge-info
              Processing
            .progress.progress-xs
              .progress-bar.bg-success{ style: "width: #{o.progress_as_percent}" }
            %center
              %small
                #{o.progress_as_percent}
          - elsif o.done?
            .badge.badge-success
              Done
          - elsif o.error?
            .badge.badge-danger
              Error
          - elsif o.closed?
            .badge.badge-warning
              Closed
        %td.text-center
          %small
            #{o.created_at.localtime}
        %td.text-center
          %small
            #{o.updated_at.localtime}
