%ol.breadcrumb
  %li.breadcrumb-item
    = link_to accounting_year_end_closings_path do
      .fa.fa-file
      Year End Closing Records
  %li.breadcrumb-item
    For Branch #{@branch} - #{@year}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      - if @record.status == "done"
        = link_to "#", class: 'btn', id: 'btn-approve' do
          .fa.fa-check
          Approve
        = link_to accounting_year_end_closing_path(@record), method: :delete, class: 'btn', data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
