%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      Clip Claims From
  %li.breadcrumb-item
    .fa.fa-user
    = link_to members_path(@clip_claim.member) do
      #{@clip_claim.member.full_name}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to edit_member_clip_claim_path(@clip_claim.member, @clip_claim), class: 'btn btn-app' do
        %i.fa.fa-edit
        Edit
    .btn-group 
      = link_to clip_claim_path(@clip_claim), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-app" do
        %i.fa.fa-times
        Delete
    .btn-group    
      = link_to clip_claim_clip_claim_validation_pdf_path(@clip_claim), target: "_blank", class: "btn btn-app" do
        .fa.fa-download
        Validation PDF
    .btn-group 
      = link_to clip_claim_clip_claim_loa_pdf_path(@clip_claim), target: "_blank", class: "btn btn-app" do
        .fa.fa-print
        LOA
    .btn-group
      = link_to clip_claims_path do
        .fa.fa-arrow-left
        Back to Clip Claims