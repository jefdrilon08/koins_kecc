#modal-note.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Add Note
      .modal-body
        .modal-body-content
          .callout.callout-info
            %p
              Add note for claims
          .row
            .col
              .form-group
                = text_area_tag :note, @note, class: "form-control", id: "input-note"
          .message
      .modal-footer
        .controls
          %button#btn-save-note.btn.btn-primary
            .fa.fa-check
            Save
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel