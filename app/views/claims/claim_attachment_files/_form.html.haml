- if @claim_attachment_file.errors.any?
  .callout.callout-danger
    %h5
      Errors
    %ul
      - @claim_attachment_file.errors.full_messages.each do |e|
        %li
          #{e}

= simple_form_for [@claim, @claim_attachment_file] do |f|
  / .form-group
  /   = f.input :file_name, input_html: { class: 'form-control' }, as: :select, collection: ClaimAttachmentFile::FILE_NAMES
  .form-group
    = f.input :files, as: :file, input_html: { class: 'form-control' , multiple: true}
  %hr
  .btn-group
    %button.btn.btn-primary{ type: "submit" }
      .fa.fa-check
      Save
    = link_to claim_path(@claim), class: 'btn btn-danger' do
      .fa.fa-times
      Cancel
