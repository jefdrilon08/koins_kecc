%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      Kuya Jun Scholarship Program
  %li.breadcrumb-item
    .fa.fa-user
    = link_to "#{@claim.member.full_name}", member_path(@claim.member), target: "_blank"
  %li.breadcrumb-menu.d-md-down-none
    - if @claim.approved?
      - if @claim.data["year_level"] == "GRADE 7" || @claim.data["year_level"] == "GRADE 8" || @claim.data["year_level"] == "GRADE 9" || @claim.data["year_level"] == "GRADE 10" || @claim.data["year_level"] == "GRADE 11" || @claim.data["year_level"] == "GRADE 12"
        .btn-group    
          = link_to claim_scholarship_contract_highschool_pdf_path(@claim), target: "_blank", class: "btn btn-app" do
            .fa.fa-download
            Scholarship Contract for Highschool
      - else
        .btn-group    
          = link_to claim_scholarship_contract_college_pdf_path(@claim), target: "_blank", class: "btn btn-app" do
            .fa.fa-download
            Scholarship Contract for College
      .btn-group    
        = link_to claim_scholarship_validation_pdf_path(@claim), target: "_blank", class: "btn btn-app" do
          .fa.fa-download
          Validation PDF
      .btn-group 
        = link_to claim_scholarship_loa_pdf_path(@claim), target: "_blank", class: "btn btn-app" do
          .fa.fa-print
          LOA
      .btn-group
        = link_to claims_path do
          .fa.fa-arrow-left
          Back to Claims
    - else
      .btn-group
        = link_to "", class: "btn btn-app", id: "approved-button"  do
          .fa.fa-check
          Approved
      .btn-group
        = link_to edit_claim_path(@claim), class: 'btn btn-app' do
          %i.fa.fa-edit
          Edit
      .btn-group 
        = link_to claim_path(@claim), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-app" do
          %i.fa.fa-times
          Delete
      .btn-group
        = link_to claims_path do
          .fa.fa-arrow-left
          Back to Claims