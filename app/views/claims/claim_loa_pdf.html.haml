:css
  .print-text {
    font-size: 1.7em;
    font-family: arial;
  }

  .print-text-book {
    font-size: 1.4em;
    font-family: arial;
  }

  .print-text-sub {
    font-size: .8em;
    font-family: arial;
  }

  .signatories{
    width: 100%;
  }

  #kmba{
    padding: -5px 5px 5px 5px;
    width: 20%;
  }

  .body1{
    width: 100%;
    padding: 0px 0px 0px 45px;
  }
 
  .body2{
    width: 100%;
  }


%span.print-text
  %left
    = image_tag("kmba.ico", :alt => "kmba img", id: "kmba")
  %br
    - if !@claim.date_reported.nil?
      #{@claim.date_reported.strftime("%b %d, %Y")}
    - else
      #{@claim.date_prepared.strftime("%b %d, %Y")}
  %left
    - if @cluster.id == "4350b839-9774-4b0a-a79b-f71409ad6d2b" 
      %p
        %b
          CEBU ARCHDIOCESAN PROGRAM FOR SELF RELIANCE INC.-CAPS-R
        %br
          %b
            Cebu Caritas Building, P. Gomez St., Cebu City, Philippines
    - elsif @cluster.id == "168eb8bf-59b4-4401-9498-79c87b3c01d4"
      %p
        %b
          JAIME V. ONGPIN MICROFINANCE FOUNDATION INC. (JVOMFI)
        %br
          %b
            Baguio City, Philippines
    - else
      %p
        %b
          KASAGANA-KA CREDIT AND SAVING COOPERATIVE
        %br
          %b
            5 Don Francisco St. Don Enrique Hiehgts , Quezon City
    %p
      Attention:
      %br
      .body1
        Re:    
        %table{:border => "0"}
