            %td{:width => "25%"}
              %u  
                //#{@claim.retirement_fund}
                &#8369;&nbsp;#{number_with_delimiter(number_with_precision(@claim.retirement_fund, precision: 2), delimiter: ",", separator: ".", unit: "")}&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; 
          %tr
            %td{:width => "21%"}
              Cause of Death:
            %td{:width => "25%"}
              %u  
                #{@claim.cause_of_death_tpd_accident}
          %tr
            %td{:width => "21%"}
