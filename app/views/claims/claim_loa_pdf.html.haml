            %u
              %b
                #{@claim.name_of_insured}
            &nbsp;loss assured from CAPS-R
            %u
              %b
                #{@member.branch}
            &nbsp;branch with the amount of
            %u
              %b
                ***#{@claim.total_amount_payable.to_f.to_words.titleize} Only***&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8369;(#{number_with_delimiter(number_with_precision(@claim.total_amount_payable, precision: 2), delimiter: ",", separator: ".", unit: "")})
          %br
            Thank you for your cooperation in this regard.
      - elsif @cluster.id == "168eb8bf-59b4-4401-9498-79c87b3c01d4"
        %p
          Dear Sir/Madam:
          %br
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;This will serve as your authority to proceed the realease of the above claims in favor of
            %b
              %u
                #{@claim.beneficiary}
