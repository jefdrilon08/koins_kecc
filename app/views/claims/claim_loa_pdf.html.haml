            %td{:width => "21%"}
              Name of Member:
            %td{:width => "25%"}
              %u
                #{@claim.member.check_name}
          %tr
            %td{:width => "21%"}
              Name of Loss Assured:
            %td{:width => "25%"}
              %u  
                #{@claim.name_of_insured}  
          %tr
            %td{:width => "21%"}
              Classification:
            %td{:width => "25%"}
              %u  
                #{@claim.classification_of_insured}
