%section.content-header
  %h3
    %strong
      CLIP Details
- if @claim.approved?
  .bs-callout.bs-callout-primary
    %h3
      .fa.fa-book
      This has already been posted by #{@claim.posted_by} on #{@claim.date_posted}
- elsif @claim.for_posting?
  .bs-callout.bs-callout-primary
    %h3
      .fa.fa-thunbs-up
      This has already been approved by #{@claim.approved_by} on #{@claim.date_approved}
- elsif @claim.for_approval?
  .bs-callout.bs-callout-primary
    %h3
      .fa.fa-check
      This has already been checked by #{@claim.checked_by} on #{@claim.date_checked}
%table.table.table-sm.table-hover
  %tbody
    %tr
      %th Date Prepared
      %td
        = @claim.try(:date_prepared).try(:strftime, "%b %d, %Y")
      %th
      %td
    %tr
      %th Branch
      %td
        = @claim.member.branch.name
      %th Debtors Name (Member)
      %td 
        = link_to "#{@claim.member.full_name} (#{@claim.member.identification_number})", member_path(@claim.member), target: "_blank"
    %tr
      %th Beneficiary
      %td 
        = @data[:beneficiary]
      %th Date of Birth
      %td 
        = @data[:date_of_birth].to_date.try(:strftime, "%b %d, %Y")
    %tr
      %th Age
      %td 
        = @data[:age]
      %th Creditors Name
      %td 
        = @data[:creditors_name]
    %tr
      %th Date of Death
      %td
        = @data[:date_of_death].to_date.try(:strftime, "%b %d, %Y")
      %th Cause of Death
      %td
        = @data[:cause_of_death]
    %tr
      %th Type of Loan
      %td
        = @data[:type_of_loan]
      %th Term of Loan
      %td
        = @data[:terms]
    %tr
      %th Effective Date of Coverage
      %td
        = @data[:effective_date_of_coverage].to_date.try(:strftime, "%b %d, %Y")
      %th Expiration Date of Coverage
      %td
        = @data[:expiration_date_of_coverage].to_date.try(:strftime, "%b %d, %Y")
    %tr
      %th Policy Number
      %td 
        = @data[:policy_number]  
      %th Amount of Loan
      %td
        = @data[:amount_of_loan]
    %tr
      %th Amount Payable to Beneficiary (Paid Amount)
      %td
        = @data[:amount]
      %th Amount Payable to Creditor (Balance)
      %td
        = @data[:amount_payable_to_creditor]
    %tr
      %th Prepared By
      %td
        = @claim.prepared_by
      %th Transaction Type
      %td
        = @data[:transaction_type]
    %tr
      %th CB Uploaded Documents
      %td
        = @claim.member.attachment_files.pluck(:file_name).map(&:inspect).join(", ")
      %th
      %td
    %tr
      %th Claims Payment Through
      %td
        = @data[:claims_payment]
      %th Claims Payment Through (Creditor)
      %td
        = @data[:claims_payment_creditor]
    %tr
      %th Account Name
      %td
        = @data[:account_name]
      %th Account Name (Creditor)
      %td
        = @data[:account_name_creditor]
    %tr
      %th Account Number
      %td
        = @data[:account_number]
      %th Account Number (Creditor)
      %td
        = @data[:account_number_creditor] 
    %tr
      %th Checked by
      %td 
        = @claim.try(:checked_by).try(:titleize)
      %th Date Checked
      %td 
        = @claim.try(:date_checked).try(:strftime, "%b %d, %Y")
    %tr
      %th Approved by
      %td 
        = @claim.try(:approved_by).try(:titleize)
      %th Date Approved
      %td 
        = @claim.try(:date_approved).try(:strftime, "%b %d, %Y")
    %tr
      %th Posted by
      %td 
        = @claim.try(:posted_by).try(:titleize)
      %th Date Posted
      %td 
        = @claim.try(:date_posted).try(:strftime, "%b %d, %Y")
- if @claim.note.present?
  - if @claim.pending?  
    .bs-callout.bs-callout-primary
      .alert.alert-info  
        %p
          %b
            NOTE:
          #{@claim.note}
- if @claim.declined_note.present?
  - if @claim.pending?  
    .bs-callout.bs-callout-primary  
      .alert.alert-danger  
        %p
          %i.fa.fa-warning{:style => "font-size:40px;color:red"}
          %b
            DECLINED NOTE:
          #{@claim.declined_note}


    

