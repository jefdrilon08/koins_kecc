%section.content-header
  %h3
    %strong
      HIIP Details
- if @claim.approved?
  .bs-callout.bs-callout-primary
    %h3
      .fa.fa-book
      This has already been posted by #{@claim.posted_by} on #{@claim.date_posted}
- elsif @claim.for_posting?
  .bs-callout.bs-callout-primary
    %h3
      .fa.fa-thunbs-up
      This has already been approved by #{@claim.approved_by} on #{@claim.date_approved}
- elsif @claim.for_approval?
  .bs-callout.bs-callout-primary
    %h3
      .fa.fa-check
      This has already been checked by #{@claim.checked_by} on #{@claim.date_checked}
%table.table.table-sm.table-hover
  %tbody
    %tr
      %th Branch
      %td
        = @claim.member.branch.name
      %th Name
      %td 
        = link_to "#{@claim.member.full_name} (#{@claim.member.identification_number})", member_path(@claim.member), target: "_blank"
    %tr
      %th Date Prepared
      %td 
        = @claim.date_prepared.strftime("%b %d, %Y")
      %th Date of Birth
      %td 
        = @data[:date_of_birth].to_date.strftime("%b %d, %Y")   
    %tr
      %th Effective Date of Coverage
      %td 
        = @data[:effective_date_of_coverage].to_date.strftime("%b %d, %Y")
      %th Expiration Date of Coverage
      %td 
        = @data[:expiration_date_of_coverage].to_date.strftime("%b %d, %Y")    
    %tr
      %th Date Admitted
      %td 
        = @data[:date_admitted].to_date.strftime("%b %d, %Y") 
      %th Date Discharged
      %td 
        = @data[:date_discharged].to_date.strftime("%b %d, %Y")  
    %tr
      %th Reason of Confinement
      %td 
        = @data[:reason_of_confinement] 
      %th Diagnosis
      %td 
        = @data[:diagnosis] 
    %tr
      %th Certificate No.
      %td 
        = @data[:certificate_number] 
      %th Amount
      %td 
        = @data[:amount]
    %tr
      %th Name of Claimant
      %td 
        = @data[:name_of_claimant]
      %th Age
      %td 
        = @data[:age]
    %tr
      %th Number of days to be paid
      %td
        = @data[:number_of_days_tobepaid]
      %th Prepared By
      %td
        = @claim.prepared_by
    %tr
      %th CB Uploaded Documents
      %td
        = @claim.member.attachment_files.pluck(:file_name).map(&:inspect).join(", ")
      %th
      %td
    %tr
      %th Claims Payment Through
      %td
        = @data[:claims_payment]
      %th
      %td
    %tr
      %th Account Name
      %td
        = @data[:account_name]
      %th Account Number
      %td
        = @data[:account_number]
    %tr
      %th Checked by
      %td 
        = @claim.try(:checked_by).try(:titleize)
      %th Date Checked
      %td 
        = @claim.try(:date_checked).try(:strftime, "%b %d, %Y")
    %tr
      %th Approved by
      %td 
        = @claim.try(:approved_by).try(:titleize)
      %th Date Approved
      %td 
        = @claim.try(:date_approved).try(:strftime, "%b %d, %Y")
    %tr
      %th Posted by
      %td 
        = @claim.try(:posted_by).try(:titleize)
      %th Date Posted
      %td 
        = @claim.try(:date_posted).try(:strftime, "%b %d, %Y")
- if @claim.note.present?
  - if @claim.pending?  
    .bs-callout.bs-callout-primary
      %p
        %b
          NOTE:
        #{@claim.note}
        %hr


     