:css
  .print-text {
    font-size: 1.7em;
    font-family: arial;
  }

  .print-text-book {
    font-size: 1.4em;
    font-family: arial;
  }

  .print-text-sub {
    font-size: .8em;
    font-family: arial;
  }

  .signatories{
    width: 100%;
  }

  #kmba{
    padding: -5px 5px 5px 5px;
    width: 20%;
  }

  .body1{
    width: 100%;
    padding: 0px 0px 0px 45px;
  }
 
  .body2{
    width: 100%;
  }


%span.print-text
  %left
    = image_tag("kmba.ico", :alt => "kmba img", id: "kmba")
  %br
    #{Time.now.strftime("%B %d, %Y")}
  %left
    - if @claim.member.branch.cluster.id == "4350b839-9774-4b0a-a79b-f71409ad6d2b" 
      %p
        %b
          CEBU ARCHDIOCESAN PROGRAM FOR SELF RELIANCE INC.-CAPS-R
        %br
          %b
            Cebu Caritas Building, P. Gomez St., Cebu City, Philippines
    - elsif @claim.member.branch.cluster.id == "168eb8bf-59b4-4401-9498-79c87b3c01d4"
      %p
        %b
          JAIME V. ONGPIN MICROFINANCE FOUNDATION INC. (JVOMFI)
        %br
          %b
            Baguio City, Philippines
    - else
      %p
        %b
          KASAGANA-KA CREDIT AND SAVING COOPERATIVE
        %br
          %b
            5 Don Francisco St. Don Enrique Heights , Quezon City
    %p
      Attention:
      %br
      .body1   
        %table{:border => "0"}
          %tr
            %td{:width => "21%"}
              Branch:
            %td{:width => "25%"}
              %u  
                #{@claim.member.branch.name}
          %tr
            %td{:width => "21%"}
              Name of Insured:
            %td{:width => "25%"}
              %u  
                #{@claim.member.full_name}
          %tr
            %td{:width => "21%"}
              Payable:
            %td{:width => "25%"}
              %u  
                &#8369;&nbsp;#{number_with_delimiter(number_with_precision(@data["amount"], precision: 2), delimiter: ",", separator: ".")}
          %tr
            %td{:width => "21%"}
              Name of Claimant:
            %td{:width => "25%"}
              %u  
                #{@claim.member.full_name}

    %br
    .body2  
      - if @claim.member.branch.cluster.id == "4350b839-9774-4b0a-a79b-f71409ad6d2b"
        %p
          Dear Sir/Madam:
          %br
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;This will serve as your authority to proceed the realease of the above claims in favor of
          %b
            %u
              #{@claim.member.full_name}
          &nbsp;claimant for Hospitalization Assistance of
          %u
            %b
              #{@claim.member.full_name}
          &nbsp;loss assured from #{@claim.member.branch.cluster.name}
          %u
            %b
              #{@claim.member.branch.name}
          &nbsp;branch with the amount of
          %u
            %b
              ***#{@data["amount"].to_f.to_words.titleize} Only***&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8369;(#{number_with_delimiter(number_with_precision(@data["amount"], precision: 2), delimiter: ",", separator: ".", unit: "")})
        %br
          Thank you for your cooperation in this regard.
      - elsif @claim.member.branch.cluster.id == "168eb8bf-59b4-4401-9498-79c87b3c01d4"
        %p
          Dear Sir/Madam:
          %br
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;This will serve as your authority to proceed the realease of the above claims in favor of
          %b
            %u
              #{@claim.member.full_name}
          &nbsp;claimant for Hospitalization Assistance of
          %u
            %b
              #{@claim.member.full_name}
          &nbsp;loss assured from #{@claim.member.branch.cluster.name}
          %u
            %b
              #{@claim.member.branch.name}
          &nbsp;branch with the amount of
          %u
            %b
              ***#{@data["amount"].to_f.to_words.titleize} Only***&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&#8369;(#{number_with_delimiter(number_with_precision(@data["amount"], precision: 2), delimiter: ",", separator: ".", unit: "")})
        %br
          Thank you for your cooperation in this regard.
  %br
  .signatories
    %table{:border => "0"}
      %tr
        %td{:width => "25%"}
          Sincerely Yours:
          %br
          %br
          %u
            #{@claim.prepared_by}
          %br
          Account Officer
        %td{:width => "25%"}
          Check and Approved by:
          %br
          %br
          %u
            Silvida Reyes - Antiquera
          %br
            KMBA - General Manager