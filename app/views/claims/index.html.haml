= title
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            = render partial: "claims/new_transaction"
            = render partial: "claims/filter"

            - if @claims.any?
              = render partial: "claims/list", locals: { claims: @claims }
              = paginate @claims
            - else
              No claims found.
