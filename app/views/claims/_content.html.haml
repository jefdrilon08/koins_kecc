.container-fluid
  .row
    .col
      .card
        .card-body
          - if @claim.claim_type == "BLIP"
            = render partial: "claims/details/blip_details", locals: { claim: @claim }
          - elsif @claim.claim_type == "CLIP"
            = render partial: "claims/details/clip_details", locals: { claim: @claim }
          - elsif @claim.claim_type == "HIIP"
            = render partial: "claims/details/hiip_details", locals: { claim: @claim }
          - elsif @claim.claim_type == "K-KALINGA"
            = render partial: "claims/details/kalinga_details", locals: { claim: @claim } 
          - elsif @claim.claim_type == "CALAMITY ASSISTANCE"
            = render partial: "claims/details/calamity_details", locals: { claim: @claim } 
          - elsif @claim.claim_type == "K-BENTE"
            = render partial: "claims/details/kbente_details", locals: { claim: @claim }
          - elsif @claim.claim_type == "KUYA JUN SCHOLARSHIP PROGRAM"
            = render partial: "claims/details/scholarship_details", locals: { claim: @claim }