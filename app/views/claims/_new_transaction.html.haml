#modal-new-transaction.modal.fade{:tabindex => "-1"}
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          Please select a member to apply for new claim application 
      .modal-body
        .modal-body-content
          .row
            .col-md-12
              .form-group
                %label
                  Type of Claims
                = select_tag :claim_type, options_for_select(["BLIP", "CLIP", "HIIP", "CALAMITY ASSISTANCE", "K-KALINGA", "K-BENTE", "KUYA JUN SCHOLARSHIP PROGRAM"]), class: 'form-control select-select2', prompt: "-- SELECT --", id: "type-of-claims"
          .row
            .col-md-12
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "select-branch", prompt: "-- SELECT --"
          .row
            .col-md-12
              .form-group
                %label
                  Center
                = select_tag :center_id, options_for_select([]), class: "form-control select-select2 js-searchable", id: "select-center", prompt: "-- SELECT --"
          .row
            .col-md-12
              .form-group
                %label
                  Member
                = select_tag :member_id, options_for_select([]), class: "form-control select-select2 js-searchable", id: "select-member", prompt: "-- SELECT --"
          .message
      .modal-footer
        .controls
          %button#btn-confirm.btn.btn-primary 
            .fa.fa-plus
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel

