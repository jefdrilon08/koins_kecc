%table.table.table-sm.table-bordered.table-hover
  %thead
    %tr
      %th
        Start Date
      %th
        End Date
      %th
        Category
      %th.text-center
        Status
  %tbody
    - @commission_collections.each do |o|
      %tr
        %td
          %small
            #{o.start_date.strftime("%B %d, %Y")}
        %td
          %small
            #{o.end_date.strftime("%B %d, %Y")}
        %td
          = link_to commission_collection_path(o) do
            %strong
              #{o.category.upcase}
        %td.text-center
          - if o.pending?
            .badge.badge-warning
              Pending
          - elsif o.processing?
            .badge.badge-info
              Processing
          - elsif o.approved?
            .badge.badge-success
              Approved
          - elsif o.error?
            .badge.badge-danger
              Error
