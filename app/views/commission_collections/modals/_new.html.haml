#modal-new.modal.fade{:tabindex => "-1"}
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          New Commission Collection
      .modal-body
        .modal-body-content
          .row
            .col
              .form-group
                %label
                  Start Date
                = text_field_tag :start_date, Date.today, type: 'date', id: 'input-start-date', class: 'form-control'
            .col
              .form-group
                %label
                  End Date
                = text_field_tag :end_date, Date.today, type: 'date', id: 'input-end-date', class: 'form-control'
            .col
              .form-group
                %label
                  Category
                = select_tag :category, options_for_select(["referrer", "insurance coordinator"]), class: "form-control select-select2", id: "select-category"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
