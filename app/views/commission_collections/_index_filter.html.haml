= form_tag "", method: 'GET' do
  .row
    .col
      .form-group
        %label
          Start Date
        = text_field_tag :start_date, params[:start_date], class: 'form-control', type: :date
    .col
      .form-group
        %label
          End Date
        = text_field_tag :end_date, params[:end_date], class: 'form-control', type: :date
    .col
      .form-group
        %label
          Status
        = select_tag :status, options_for_select(MonthlyClosingCollection::STATUSES, @status), class: "form-control select-select2", id: "status-select", prompt: "-- SELECT --"
    .col
      .form-group
        %label
          Actions
        = button_tag type: 'submit', class: 'btn btn-info btn-block' do
          .bi.bi-search
