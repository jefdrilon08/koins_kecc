#modal-new-channel.modal.fade
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            %form
            .mb-3
              %label Transfer Option Name
              %input#transferoption.form-control
            .mb-3
              %label Code
              %input#code.form-control
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new-channel.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
