%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-database
    Data Stores
  %li.breadcrumb-item
    = link_to "/data_stores/repayment_rates" do
      .fa.fa-database
      Repayment Rates
  - if !@record.error?
    %li.breadcrumb-item
      .fa.fa-file
      #{@record.data.with_indifferent_access[:branch][:name]} - 
      #{@record.meta.with_indifferent_access[:as_of].to_date.strftime("%B %d, %Y")}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to "/data_stores/repayment_rates/#{@record.id}", method: :delete, class: 'btn', data: { confirm: "Are you sure?" } do
        .fa.fa-times
        Delete
