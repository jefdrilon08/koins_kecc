#modal-new.modal.fade{:tabindex => "-1"}
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          Dormant
      .modal-body
        .modal-body-content
          .row
            .col-md-6.col-xs-12
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "select-branch", prompt: "-- SELECT --"
            .col-md-6.col-xs-12
              .form-group
                %label
                  As of Date
                = text_field_tag :as_of, Date.today, type: :date, id: "input-as-of", class: 'form-control'
          .message
      .modal-footer
        .controls
          %button#btn-confirm.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
