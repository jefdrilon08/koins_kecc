%div{ style: "margin-bottom: 25px;" }
  %div{ style: "max-height: 300px; overflow-y: auto;" }
    %table.table.table-bordered.table-sm.table-hover{ style: "width: 100%;" }
      %thead
        %tr
          %th{ width: "30%" }
            Member
          %th{ style: "min-width: 100px;" } Center
          %th{ style: "min-width: 100px;" } Status
          %th{ style: "min-width: 100px;" } K-IMPOK
          %th{ style: "min-width: 100px;" } Dormant Fee
          -# %th{ style: "min-width: 40px;" } TOTAL
      %tbody
        - if @dormant_records.present?
          - @dormant_records.each do |record|
            %tr
              %td
                - if record[:member_id].present?
                  = link_to member_path(record[:member_id]), target: "_blank" do
                    %strong= record[:full_name]
                - else
                  %strong= record[:full_name]
              %td
                = record[:center_name]
              %td
                = record[:member_status]
              %td.text-right
                = number_to_currency(record[:balance], unit: "", precision: 2)
              %td.text-right
                = number_to_currency(record[:dormant_fee], unit: "", precision: 2)
              -# %td.text-right
              -#   = number_to_currency(record[:balance] + record[:dormant_fee], unit: "", precision: 2)
        - else
          %tr
            %td{ colspan: 6 } No dormant records found.

      %tfoot
        %tr
          %td{ colspan: 3 } 
            %strong TOTAL
          %td.text-right
            %strong= number_to_currency(@total_balance, unit: "", precision: 2)
          %td.text-right
            %strong= number_to_currency(@total_dormant_fee, unit: "", precision: 2)
          -# %td.text-right
          -#   %strong= number_to_currency(@total_balance + @total_dormant_fee, unit: "", precision: 2)
