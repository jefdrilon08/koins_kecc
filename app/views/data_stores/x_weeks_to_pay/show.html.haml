= title @record.id
= render partial: "show_header"
#parameters{ data: { id: "#{@record.id}" } }

.container-fluid
  .row
    .col
      .card
        .card-body
          - if @record.error?
            = render partial: "data_stores/error_page"
          - else
            #content
            = javascript_include_tag "XWeeksToPayShow.min.react"
