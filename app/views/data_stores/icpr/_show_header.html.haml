%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-database
    Data Stores
  %li.breadcrumb-item
    = link_to "/data_stores/icpr" do
      .fa.fa-database
      ICP
  %li.breadcrumb-item
    .fa.fa-file
    - if @record.data.with_indifferent_access[:branch].present?
      #{@record.data.with_indifferent_access[:branch][:name]} #{@record.meta.with_indifferent_access[:year]}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group

      - if @record.done?
        = link_to "#", class: 'btn', id: 'btn-approve' do
          .fa.fa-check
          Approve
        = link_to "#", class: 'btn', id: 'btn-set-rate' do
          .fa.fa-upload
          Set Rate

      = link_to "/data_stores/icpr/#{@record.id}", method: :delete, class: 'btn', data: { confirm: "Are you sure?" } do
        .fa.fa-times
        Delete
