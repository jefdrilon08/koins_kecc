%table.table.table-bordered.table-sm.table-hover.data-table
  %thead
    %tr
      %th{ width: "20%" }
        Member
      %th
        Claim Type
      %th
        Total Amount
      %th
        Date Paid 
  %tbody
    - claims.each do |c,i|
      %tr
        %td
          = link_to claim_path(c[:id]), target: '_blank' do
            #{c[:member]}
        %td
          #{c[:claim_type]}
        %td
          #{c[:amount]}
        %td
          #{c[:date_paid]}
