#modal-new.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Allowance Computation Report
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          
          .row
            .col
              .form-group
                %label
                  As Of :
                = text_field_tag :start_date, Date.new(Date.today.year, Date.today.month, 1), type: :date, id: "input-asof", class: 'form-control'
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
