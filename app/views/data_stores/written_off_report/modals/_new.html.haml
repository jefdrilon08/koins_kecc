#modal-new.modal.fade{:tabindex => "-1"}
  .modal-dialog                
    .modal-content             
      .modal-header
        %h3.modal-title
          Generate Report
      .modal-body              
        .modal-body-content
          .row
            .col-md-12.col-xs-12
              .form-group
                %strong Branch: 
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, params[:branch_id]), class: "form-control select-select2", id: "branch-select", prompt: "-- SELECT --" 
      .modal-footer            
        .controls              
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check       
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times        
            Cancel