= title @record.id
.h5
  Loan Stats #{@record.data["branch"]["name"]} - #{DateTime.parse(@record.data["as_of"]).strftime("%b %d, %Y")}
  %br
    %br
      .row
        .col
          .card
            .card-body
              - if @record.error?
                = render partial: "data_stores/error_page"
              - else
                = render partial: "show_details", locals: { record: @record }
                %hr
                = render partial: "show_officer_details", locals: { record: @record }

= render partial: "data_stores/branch_loans_stats/modals/update"
= render partial: "templates/error_list"
