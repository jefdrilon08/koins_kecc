#modal-check.modal.fade{:tabindex => "-1"}
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          Check Id Form
      .modal-body
        .modal-body-content 
          .row
            .col
              %label
                Are you sure you want to check this id form?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-check.btn.btn-primary{ "data" => {id: @data_store.id}   }
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
