= title @record.id
.h5
  Monthly Incentives #{@record.meta["branch_name"]} - #{DateTime.parse(@record.meta["as_of"]).strftime("%b %d, %Y")}
  %br
    %br
      .row
        .col
          .card
            .card-body
              - if @record.error?
                = render partial: "data_stores/error_page"
              - else
                = render partial: "data_stores/monthly_incentives/show_details"
        