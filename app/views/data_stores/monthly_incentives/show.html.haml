= title @record.id
= render partial: "show_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          - if @record.error?
            = render partial: "data_stores/error_page"
          - else
            = render partial: "data_stores/monthly_incentives/show_details"
          - if debug?
            %pre
              %code
                #{JSON.pretty_generate(JSON.parse(@record.to_json))}
