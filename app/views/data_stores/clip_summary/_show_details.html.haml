%h3
  Clip Summary
%h5
  Generated as of : #{@record.meta.with_indifferent_access[:as_of].to_date.strftime("%B %d, %Y")}
%br
%table.table.table-bordered.table-hover.table-sm
  %thead
    %tr
      %th.text-center Branch Name
      %th.text-center Identification Number
      %th.text-center Name of Member
      %th.text-center Clip Number
      %th.text-center PN Number
      %th.text-center Date Released
      %th.text-center Maturity Date
      %th.text-center Loan Term
      %th.text-center Amount
      %th.text-center Loan Product
      %th.text-center Loan Status
      %th.text-center Gender
      %th.text-center Date of Birth

  
  %tbody
    - @record[:data]['records'].each do |record|
      %tr
        %td.text-center= record['branch_name']
        %td.text-center= record['identification_number']
        %td.text-center= record['name_of_member']
        %td.text-center= record['clip_number']
        %td.text-center= record['pn_number']
        %td.text-center= record['date_released']
        %td.text-center= record['maturity_date']
        %td.text-center= record['loan_term']
        %td.text-center= record['amount']
        %td.text-center= record['loan_product']
        %td.text-center= record['loan_status']
        %td.text-center= record['gender']
        %td.text-center= record['date_of_birth']

