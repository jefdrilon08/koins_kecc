= form_tag data_stores_board_resolution_path, method: 'GET' do
  .row
    -# .col-md-5
    -#   .form-group
    -#     %label
    -#       Branch
    -#     = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, params[:branch_id]), { prompt: "-- SELECT --", class: "form-control" }
    .col-md-5
      .form-group
        %label
          Month
        = select_tag :month, options_for_select(BoardResolution::Create::MONTHS_MAPPING.keys, params[:month]), { class: "form-control", prompt: "-- SELECT --" }
    .col-md-5
      .form-group
        %label
          Year
        = select_tag :year, options_for_select((2020..Date.today.year).to_a.reverse, params[:year]), { class: "form-control", prompt: " -- SELECT --" }
    .col-md-2
      .form-group
        %label
          Actions
        .form-group
          .btn-group
            = button_tag type: 'submit', class: 'btn btn-primary btn-block' do
              .bi.bi-search
