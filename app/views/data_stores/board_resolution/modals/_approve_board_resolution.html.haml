#modal-approve-board-resolution.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Board Resolution Approve
      .modal-body
        .modal-body-content
          .row
            .col
              .c-callout.c-callout-info
                Are you sure you want to approve this Board Resolution Record?
              .message
      .modal-footer
        .controls
          %button#btn-confirm-process.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
