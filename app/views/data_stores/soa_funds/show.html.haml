- @meta = @record.meta.with_indifferent_access
- @data = @record.data.with_indifferent_access
= title @record.id
= render partial: "show_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          - if @record.error?
            = render partial: "data_stores/error_page"
          - else
            #content

#parameters{ data: { id: "#{@record.id}" } }
= javascript_include_tag "SoaFundsShow.min.react"
