#modal-new.modal.fade{:tabindex => "-1"}
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          New Data Store
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Create a new data store
          .row
            .col-md-4.col-xs-12
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "select-branch"
            .col-md-4.col-xs-12
              .form-group
                %label
                  Start Date
                = text_field_tag :as_of, @start_date, type: :date, id: "input-start-date", class: 'form-control'
            .col-md-4.col-xs-12
              .form-group
                %label
                  End Date
                = text_field_tag :as_of, @end_date, type: :date, id: "input-end-date", class: 'form-control'
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
