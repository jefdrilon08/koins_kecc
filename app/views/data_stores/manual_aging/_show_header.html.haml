%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-database
    Data Stores
  %li.breadcrumb-item
    = link_to "/data_stores/manual_aging" do
      .fa.fa-database
      Manual Aging
  %li.breadcrumb-item
    .fa.fa-file
    #{@record.data.with_indifferent_access[:branch][:name]} - 
    #{@record.meta.with_indifferent_access[:as_of].to_date.strftime("%B %d, %Y")}
  %li.breadcrumb-menu.d-md-down-none
