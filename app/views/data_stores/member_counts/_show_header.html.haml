%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-database
    Data Stores
  %li.breadcrumb-item
    = link_to "/data_stores/member_counts" do
      .fa.fa-database
      Member Counts
  - if !@record.error?
    %li.breadcrumb-item
      .fa.fa-file
      #{@record.data.with_indifferent_access[:branch][:name]}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to "/data_stores/member_counts/#{@record.id}", method: :delete, class: 'btn', data: { confirm: "Are you sure?" } do
        .fa.fa-times
        Delete
