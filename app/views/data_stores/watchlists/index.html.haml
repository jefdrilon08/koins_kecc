= title
.row
  .col
    .card
      .card-body
        = render partial: "index_filter"
        - if @records.any?
          = render partial: "index_list"
          = paginate @records
        - else
          %p
            No records

= render partial: "data_stores/watchlists/modals/new"
= render partial: "templates/error_list"

= javascript_include_tag "data_stores/watchlists/Index"

:javascript
  $(document).ready(function() {
    var authenticityToken = $("meta[name='csrf-token']").attr('content');

    Index.init({
      authenticityToken: authenticityToken
    });
  });
