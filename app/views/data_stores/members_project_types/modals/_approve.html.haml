#modal-approve.modal.fade
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          Approve
      .modal-body
        .modal-body-content
          Approve Members Project Type
      .modal-footer
        .controls
          %button#btn-confirm-approve.btn.btn-primary{data: { id: @data_store.id  }  }
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
