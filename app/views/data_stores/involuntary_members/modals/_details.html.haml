#modal-details.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Print Letter
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Print Letter for 
            %span.display-member 
          .message
      .modal-footer
        .controls
          %button.btn-confirm.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
