%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-database
    Data Stores
  %li.breadcrumb-item
    = link_to "/data_stores/monthly_new_and_resigned" do
      .fa.fa-database
      Monthly New and Resigned
  - if @record.data.with_indifferent_access[:branch].present?
    %li.breadcrumb-item
      .fa.fa-file
      #{@record.data.with_indifferent_access[:branch][:name]}
    - if @record.done?
      %li.breadcrumb-item
        .fa.fa-file
        As Of: #{@record.data.with_indifferent_access[:as_of].to_date.strftime("%B %d, %Y")}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to "/data_stores/monthly_new_and_resigned/#{@record.id}", method: :delete, class: 'btn', data: { confirm: "Are you sure?" } do
        .fa.fa-times
        Delete
