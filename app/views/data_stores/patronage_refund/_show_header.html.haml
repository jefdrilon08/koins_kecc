%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-database
    Data Stores
  %li.breadcrumb-item
    = link_to "/data_stores/patronage_refund" do
      .fa.fa-database
      Patronage Refund
  %li.breadcrumb-item
    .fa.fa-file
    - if @record.data.with_indifferent_access[:branch].present?
      #{@record.data.with_indifferent_access[:branch][:name]} #{@record.meta.with_indifferent_access[:year]}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      - if @record.done? and @record.data.with_indifferent_access[:status] == 'pending'
        = link_to "#", class: 'btn', id: 'btn-approve' do
          .fa.fa-check
          Approve
        = link_to "#", class: 'btn', id: 'btn-set-rate' do
          .fa.fa-upload
          Set Rate
        = link_to "/data_stores/patronage_refund/#{@record.id}", method: :delete, class: 'btn', data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
