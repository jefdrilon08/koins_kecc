%table.table.table-bordered.table-sm.table-hover
  %thead
    %tr
      %th.text-center
        Date
      %th
        Branch
      %th.text-center
        Status
      %th.text-center
        Last Updated
  %thead
    - @records.each do |o|
      %tr
        %td.text-center
          %strong
            = link_to "/data_stores/branch_with_centers_loans_stats/#{o.id}" do
              #{o.meta.with_indifferent_access[:as_of].to_date.strftime("%b %d, %Y")}
        %td
          #{o.meta.with_indifferent_access[:branch_name]}
        %td.text-center
          - if o.processing?
            .badge.badge-info
              Processing
          - elsif o.done?
            .badge.badge-success
              Done
          - elsif o.error?
            .badge.badge-danger
              .fa.fa-times
              ERROR
        %td.text-center
          %small
            #{o.updated_at.localtime}
