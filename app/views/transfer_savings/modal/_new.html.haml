#modal-new.modal.fade
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          Create Transfer Savings Record
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          Create Record
          .row
            .col
              .form-group
                %label
                  Select Branch:
                = select_tag :branch, options_from_collection_for_select(@branches, :id, :name), id: "select-branch", class: "form-control select-select2", prompt: "-- SELECT --"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
