.h4
  Transfer Savings Module
%table.table.table-bordered.table-sm.table-hover
  %thead
    %tr
      %th
      %th.text-center
        Branch
      %th.text-center
        Status
      %th.text-center
        Started
      %th.text-center
        Last Updated
  %thead
    - @records.each do |o|
      %tr
        %td.text-center
          = link_to "/transfer_savings/#{o.id}" do
            .bi.bi-search
        %td.text-center
          #{Branch.find(o[:branch_id]).name} 
        %td.text-center
          - if o[:status] == "processing"
            .badge.badge-info
              Processing
          - elsif o[:status] == "done"
            .badge.bg-success
              Done
          - elsif o[:status] == "pending"
            .badge.bg-danger
              pending
          - elsif o[:status] == "approved"
            .badge.bg-success
              approved
          - elsif o[:status] == "error"
            .badge.bg-danger
              Error
        %td.text-center
          %small
            #{o.created_at.localtime}
        %td.text-center
          %small
            #{o.updated_at.localtime}
