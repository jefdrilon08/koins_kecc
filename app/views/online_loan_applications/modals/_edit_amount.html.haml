#modal-edit-amount.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Approve
      .modal-body
        .modal-body-content
          .alert.alert-info
            %p
              Are you sure you want to approve this application?
          .callout.callout-info
            %table
              %tbody
                %tr
                  %th
                    %h4 Amount:
                  %td        
                    %h4
                      %input#bookId{:name => "bookId", :type => "text", :value => ""}
          .message
      .modal-footer
        .controls
          %button#btn-confirm-edit-amount.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
