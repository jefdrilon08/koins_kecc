#modal-for-approve.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          For Approve
      .modal-body
        .modal-body-content
          .alert.alert-info
            %p
              Are you sure you want move this for approve?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-for-approve.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
