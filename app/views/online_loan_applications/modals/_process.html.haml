#modal-process.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Process Application
      .modal-body
        .modal-body-content
          .alert.alert-info
            %p
              Are you sure you want to process this application?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-process.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
