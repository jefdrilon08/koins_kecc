#modal-check.modal.fade
  .modal-dialog.modal-dialog-centered
    .modal-content
      .modal-header
        %h3.modal-title
          CASH FLOW
      .modal-body
        .modal-body-content
          .alert.alert-info{style: "background-color: #eeeee4; color: black;"}
            %p
              Are you sure you want to approved cash flow?
          .message
      .modal-footer
        .controls
          %button#confirm-check.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
