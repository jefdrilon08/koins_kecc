#modal-loan-tag.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Loan Product Tag
      .modal-body
        .modal-body-content
          .callout.callout-info
            %table
              %tbody
                %tr
                  %td        
                    %h4
                      = select_tag :loan_tag, options_from_collection_for_select(@loan_tag, :id, :name,  @online_application_tag), class: "form-control select-select2", id: "select-loan-tag", prompt: "-- SELECT --"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-loan-tag.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
