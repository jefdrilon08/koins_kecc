#modal-new.modal.fade{:tabindex => "-1"}
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          New Adjustment
      .modal-body
        .modal-body-content
          .row
            .col-6
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "select-branch", prompt: "-- SELECT --"
            .col-6
              .form-group
                %label
                  Center
                = select_tag :center_id, [], class: "form-control", id: "select-center"
          .row
            .col-6
              .form-group
                %label
                  Starting Date
                = date_field_tag :date_initialized, Date.today, class: "form-control", id: "input-date-initialized"
            .col-6
              .form-group
                %label
                  Number of Days
                = number_field_tag :number_of_days, 0, class: "form-control", id: "input-number-of-days"
          .row
            .col
              .form-group
                %label
                  Reason
                = text_field_tag :reason, "", class: "form-control", id: "input-reason"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
