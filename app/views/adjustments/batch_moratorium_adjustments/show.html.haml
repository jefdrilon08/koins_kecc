= render partial: "show_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          .message
          %table.table.table-bordered.table-sm
            %tr
              %th{ width: "25%" }
                Branch
              %td
                #{@meta[:branch][:name]}
            %tr
              %th{ width: "25%" }
                Center
              %td
                - if @meta[:center][:name].present?
                  #{@meta[:center][:name]}
            %tr
              %th{ width: "25%" }
                Date Initialized
              %td
                #{@data[:date_initialized]}
            %tr
              %th{ width: "25%" }
                Number of Days
              %td
                #{@data[:number_of_days]}
            %tr
              %th{ width: "25%" }
                Reason
              %td
                #{@data[:reason]}
            %tr
              %th{ width: "25%" }
                Generated By
              %td
                #{@meta[:generated_by][:last_name]}, #{@meta[:generated_by][:first_name]}

#parameters{ data: { id: @adjustment_record.id } }

= render partial: "adjustments/batch_moratorium_adjustments/modals/approve"
= render partial: "adjustments/batch_moratorium_adjustments/modals/delete"
= render partial: "templates/error_list"

= javascript_include_tag "adjustments/batch_moratorium_adjustments/Show"

:javascript
  $(document).ready(function() {
    var authenticityToken = $("meta[name='csrf-token']").attr('content');
    var id                = $("#parameters").data("id");

    Show.init({
      authenticityToken: authenticityToken,
      id: id
    });
  });
