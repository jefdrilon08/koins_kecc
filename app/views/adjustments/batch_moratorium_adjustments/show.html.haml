= title @adjustment_record.id
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            .message
            %table.table.table-bordered.table-sm
              %tr
                %th{ width: "25%" }
                  Branch
                %td
                  #{@meta[:branch][:name]}
              %tr
                %th{ width: "25%" }
                  Center
                %td
                  - if @meta[:center][:name].present?
                    #{@meta[:center][:name]}
              %tr
                %th{ width: "25%" }
                  Date Initialized
                %td
                  #{@data[:date_initialized]}
              %tr
                %th{ width: "25%" }
                  Number of Days
                %td
                  #{@data[:number_of_days]}
              %tr
                %th{ width: "25%" }
                  Reason
                %td
                  #{@data[:reason]}
              %tr
                %th{ width: "25%" }
                  Generated By
                %td
                  #{@meta[:generated_by][:last_name]}, #{@meta[:generated_by][:first_name]}

= render partial: "adjustments/batch_moratorium_adjustments/modals/approve"
= render partial: "adjustments/batch_moratorium_adjustments/modals/delete"
= render partial: "templates/error_list"
