%table.table.table-sm.table-bordered.table-hover
  %thead
    %tr
      %th
        Date Initialized
      %th.text-center
        \# of Days
      %th
        Branch
      %th
        Center
      %th
        Generated By
      %th.text-center
        Status
      %th.text-center
        Actions
  %tbody
    - @adjustment_records.each do |o|
      %tr
        %td
          #{o.created_at.strftime("%B %d, %Y")}
        %td.text-center
          #{o.data["number_of_days"]} Days
        %td
          #{o.meta["branch"]["name"]}
        %td
          - if o.meta["center"]["name"].present?
            #{o.meta["center"]["name"]}
        %td
          #{o.meta["generated_by"]["last_name"]}, #{o.meta["generated_by"]["first_name"]}
        %td.text-center
          - if o.pending?
            .badge.badge-danger
              Pending
          - elsif o.approved?
            .badge.badge-success
              Approved
        %td.text-center
          = link_to adjustments_batch_moratorium_adjustment_path(o.id), class: 'btn btn-primary' do
            .fa.fa-search
