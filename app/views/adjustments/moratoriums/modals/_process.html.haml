#modal-process.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Process Moratorium Adjustment
      .modal-body
        .modal-body-content
          .row
            .col
              .alert.alert-info
                Are you sure you want to process this adjustment?
              .message
      .modal-footer
        .controls
          %button#btn-confirm-process.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
