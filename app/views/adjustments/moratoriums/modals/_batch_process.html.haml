#modal-batch-process.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Batch Process
      .modal-body
        .modal-body-content
          .row
            .col
              .form-group
                %label
                  Center:
                = select_tag :center_id, options_from_collection_for_select(@centers, :id, :name, @center.try(:id)), class: "form-control select-select2", id: "select-process-center", prompt: "-- SELECT --"

              .message
      .modal-footer
        .controls
          %button#btn-confirm-batch-process.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
