#modal-new.modal.fade{:tabindex => "-1"}
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          New Moratorium Adjustment
      .modal-body
        .modal-body-content
          .row
            .col-md-6.col-xs-12
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "select-branch", prompt: "-- SELECT --"
            .col-md-6.col-xs-12
              .form-group
                %label
                  Center
                = select_tag :center_id, options_from_collection_for_select([], :id, :name), class: "form-control select-select2", id: "select-center", prompt: "-- SELECT --"
          .row
            .col
              .form-group
                %label
                  Member
                = select_tag :member_id, options_for_select([]), class: "form-control select-select2", id: "select-member", prompt: "-- SELECT --"
          .row
            .col
              .form-group
                %label
                  Loans
                = select_tag :loan_ids, options_for_select([]), class: "form-control select-select2 js-searchable", id: "select-loans", multiple: true
          .row
            .col-md-6.col-xs-12
              .form-group
                %label
                  Date Initialized
                = date_field_tag :date_initialized, Date.today, class: "form-control", id: "input-date-initialized"
            .col-md-6.col-xs-12
              .form-group
                %label
                  Number of Days
                = number_field_tag :number_of_days, 0, class: "form-control", id: "input-number-of-days"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
