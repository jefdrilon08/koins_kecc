= title @adjustment_record.id
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            - if @adjustment_record.pending?
              = render partial: "form_add"
            .message

            - if @data[:records].any?
              = render partial: "members_table"
            - else
              %p
                No records found.
            %hr

            %h4
              Accounting Entry
            - if @adjustment_record.pending?
              = render partial: "accounting_entry_controls"
            = render partial: "accounting_entry_display", locals: { accounting_entry: @accounting_entry }

= render partial: "adjustments/subsidiary_adjustments/modals/approve"
= render partial: "adjustments/subsidiary_adjustments/modals/delete"
= render partial: "adjustments/subsidiary_adjustments/modals/delete_member"
= render partial: "adjustments/subsidiary_adjustments/modals/delete_accounting_entry"
= render partial: "templates/error_list"
