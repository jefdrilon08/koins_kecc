%table.table.table-sm.table-bordered.table-hover
  %thead
    %tr
      %th
        Date
      %th
        Branch
      %th
        Generated By
      %th.text-center
        Status
      %th
        Particular
      %th.text-center
        Actions
  %tbody
    - @adjustment_records.order(created_at: :desc).each do |o|
      %tr
        %td
          #{o.created_at.strftime("%B %d, %Y")}
        %td
          #{o.meta["branch"]["name"]}
        %td
          #{o.meta["generated_by"]["last_name"]}, #{o.meta["generated_by"]["first_name"]}
        %td.text-center
          - if o.pending?
            .badge.badge-danger
              Pending
          - elsif o.approved?
            .badge.badge-success
              Approved
        %td
          -if o.data["accounting_entry"].present?
            #{o.data["accounting_entry"]["particular"]}
        %td.text-center
          = link_to adjustments_subsidiary_adjustment_path(o.id), class: 'btn btn-primary' do
            .fa.fa-search
