%table.table.table-sm.table-bordered.table-hover
  %thead
    %tr
      %th
        Date
      %th
        Branch
      %th
        Generated By
      %th.text-center
        Status
      %th
        Actions
  %tbody
    - @adjustment_records.each do |o|
      %tr
        %td
          #{o.created_at.strftime("%B %d, %Y")}
        %td
          #{o.meta["branch"]["name"]}
        %td
          #{o.meta["generated_by"]["last_name"]}, #{o.meta["generated_by"]["first_name"]}
        %td.text-center
