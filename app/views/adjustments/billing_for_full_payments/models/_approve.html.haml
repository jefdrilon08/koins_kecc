#modal-approve.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Approve Recomputation
      .modal-body
        .modal-body-content
          .callout.callout-info
            %p
              Are you sure you want to approve this Recomputation of K-SAGIP?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-approve.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
