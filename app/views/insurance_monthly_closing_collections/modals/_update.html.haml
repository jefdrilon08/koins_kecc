#modal-update.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          New Monthly Closing Collection
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Are you sure you want to update this record?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-update.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
