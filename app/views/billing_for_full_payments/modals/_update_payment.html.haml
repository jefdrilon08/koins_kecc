#modal-change-payment.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          %table
            %tbody
              %tr
                %th 
                  %h4 Member: 
                %td 
                  
                  %h4#memberName{:name => "memberName"}
            
              %tr
                %th 
                  %h4 Transaction:
                %td 
                  %h4 Withdraw Payment
      .modal-body
        .modal-body-content
          .callout.callout-info
            %table
              %tbody
                %tr
                  %th
                    %h4 Amount:
                  %td        
                    %h4
                      %input#bookId{:name => "bookId", :type => "text", :value => ""}
          .message
      .modal-footer
        .controls
          %button#btn-confirm-approve.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
