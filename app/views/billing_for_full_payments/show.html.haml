.row
  .col
    .card
      .card-body
        %h5
          Billing for fullpayment in
          #{Branch.find(@billing_data_store.meta["branch_id"]).name } / 
          #{Center.find(@billing_data_store.meta["center_id"]).name } - 
          #{@billing_data_store.meta["collection_date"]}
        

        - if @billing_data_store["status"] == "pending"
          = render partial: "form_add"
        - else
          = render partial: "approved_form"


        %table.table.table-sm.table-bordered
          %thead
            %tr
              %th
                Member
              - @billing_data_store.meta["header"].last.each_with_index do |bdsh, i|
                - if bdsh["loan_product"] == "WP"
                  %th
                    WP
                - else
                  %th
                    #{LoanProduct.find(bdsh["loan_product"]).name}
                  
            
            
            
            
          %tbody
            - @billing_data_store.data.each do |bds|
              - if bds["status"] == "active"
                %tr
                  
                  %td
                    #{Member.find(bds["member_id"]).full_name}
                
                  - bds["balance"].each do |b|
                    - if b["record_type"] == "WP"
                      - if b["enabled"] == true
                        %td
                          - if @billing_data_store["status"] == "pending"
                            %a.undo{ data: { 
                                      amount: "#{b["amount"]}",
                                      member_id: "#{bds["member_id"]}",
                                      member_account_id: "#{b["member_account_id"]}",
                                      member_account_name: "#{Member.find(bds["member_id"]).full_name}",
                                      data_store_id: "#{@billing_data_store.id}",
                                      record_type: "#{b["record_type"]}"
                                    }, 
                                    :href => "#" 
                              }

                              #{b["amount"]}
                          - else
                            #{b["amount"]}
                      - else
                        %td
                    - else
                      %td
                        - if b["amount"] > 0
                          - if @billing_data_store["status"] == "pending"
                            %a.remove_amount{ data: {
                                                  amount: "#{b["amount"]}",
                                                  member_id: "#{bds["member_id"]}",
                                                  loan_id: "#{b["loan_id"]}",
                                                  loan_product_id: "#{b["loan_product_id"]}",
                                                  member_account_id: "#{b["member_account_id"]}",
                                                  data_store_id: "#{@billing_data_store.id}",
                                                  record_type: "#{b["record_type"]}",
                                                  loan_product_name: "#{LoanProduct.find(b["loan_product_id"]).name}",
                                                  member_account_name: "#{Member.find(bds["member_id"]).full_name}"
                                          

                                          },
                                          :href => "#"
                                        }
                              #{b["amount"]}
                          - else
                            #{b["amount"]}
            %tr
              %th{colspan: 2}
                Total
                      


= render partial: "accounting_entry_display", locals: { accounting_entry: @record }
= render partial: "/billing_for_full_payments/modals/update_payment"
= render partial: "/billing_for_full_payments/modals/remove_payment"
= render partial: "/billing_for_full_payments/modals/check"
= render partial: "/billing_for_full_payments/modals/approve"
