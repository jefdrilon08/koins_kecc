= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            %h2
              #{@survey_answer.survey}
            %hr
            - @data[:answers].each do |o|
              %h4
                #{o[:survey_question][:content]}: #{o[:answer]} - #{o[:score]}
              - o[:survey_question][:data][:options].each do |option|
                %div
                  - if option[:content] == o[:answer]
                    .badge.badge-success
                      .fa.fa-check
                    #{option[:content]}
                  - else
                    .badge.badge-danger
                      .fa.fa-times
                    #{option[:content]}
              %hr

= render partial: "members/modals/delete_survey_answer"
= render partial: "templates/error_list"
