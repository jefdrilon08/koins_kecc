= render partial: "show_header"

.container-fluid
  .row{:style => "margin-top: 20px;"}
    .col-md-4.col-xs-12
      = render partial: "member_semi_details"
    .col-md-8.col-xs-12
      = render partial: "member_details"

= render partial: "members/modals/generate_access_token"
= render partial: "members/modals/signature"
= render partial: "members/modals/new_loan"
= render partial: "members/modals/create_survey"
= render partial: "members/modals/delete"
= render partial: "members/modals/unlock"
= render partial: "members/modals/restore"
= render partial: "members/modals/change_member_type"
= render partial: "members/modals/change_recognition_date"
= render partial: "members/modals/resign_from_insurance"
= render partial: "members/modals/upload_profile_picture"
= render partial: "templates/error_list"

= javascript_include_tag "members/Show.js"

= stylesheet_link_tag "member"

#parameters{ data: { member_id: @member.id } }

:javascript
  $(document).ready(function() {
    var $parameters       = $("#parameters");
    var memberId          = $parameters.data("member-id");
    var authenticityToken = $('meta[name="csrf-token"]').attr( 'content' );

    Show.init(memberId, authenticityToken);
  });
