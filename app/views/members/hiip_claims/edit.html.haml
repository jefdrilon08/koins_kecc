%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      HIIP Information
  %li.breadcrumb-item
    .fa.fa-user
      Edit Record for: #{link_to @member.full_name, member_path(@member), target: '_blank'}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to hiip_claims_path do
        .fa.fa-arrow-left
        Back to HIIP Claims

.container-fluid
  .row
    .col
      .card
        .card-body
          = render partial: "members/hiip_claims/form", locals: { hiip_claim: @hiip_claim }

