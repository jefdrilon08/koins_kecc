%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      HIIP Form
  %li.breadcrumb-item
    .fa.fa-user
    = link_to members_path(@member) do
      #{@member.full_name} 
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to hiip_claims_path do
        .fa.fa-arrow-left
        Back to HIIP

.container-fluid
  .row
    .col
      .card
        .card-body
          = render partial: "members/hiip_claims/form", locals: { clip_claim: @clip_claim }
