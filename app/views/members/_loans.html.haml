%hr
%h6
  Accrued Interest
- if @active_loans.any?
  %table.table.table-bordered.table-hover.table-sm
    %thead
      %tr
        %th PN Number
        %th Loan Product
        %th Total Due
        %th Total Paid
        %th Balance
    %tbody        
      - @active_loans.each do |loan|
        - if loan.data["accrued_interest"].present?
          %tr
            %td
              #{loan.pn_number}
            %td
              #{loan.loan_product}
            %td
              #{loan.data["accrued_interest"]["total_accrued_interest"]}
            %td
              #{loan.data["accrued_interest"]["total_accrued_interest_balance"]}
            %td
              #{loan.data.with_indifferent_access[:accrued_interest][:total_accrued_interest].to_f - loan.data.with_indifferent_access[:accrued_interest][:total_accrued_interest_balance].to_f}



