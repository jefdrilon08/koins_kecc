%hr
%h6
  Accrued Interest
%table.table.table-bordered.table-hover.table-sm
  %thead
    %tr
      %th PN Number
      %th Loan Product
      %th Total Due
      %th Total Paid
      %th Balance
      %th Status
      %th Action
  %tbody        
    - if @active_loans.any?
      - @active_loans.each do |loan|
        - if loan.data["accrued_interest"].present?
          %tr
            %td
              #{loan.pn_number}
            %td
              #{loan.loan_product}
            %td
              #{loan.data["accrued_interest"]["total_accrued_interest"]}
            %td
              #{loan.data["accrued_interest"]["total_accrued_interest_balance"]}
            %td
              #{loan.data.with_indifferent_access[:accrued_interest][:total_accrued_interest].to_f - loan.data.with_indifferent_access[:accrued_interest][:total_accrued_interest_balance].to_f}
            %td
              -if loan.data["accrued_interest"]["status"] == "remove"
                
                #{loan.data["accrued_interest"]["status"]}
              -else
                - if loan.data["accrued_interest"]["status"].present?
                  #{loan.data["accrued_interest"]["status"]}
                - else
                  Active
                

            - if current_user.roles.include?("SBK")
              %td
                -if loan.data["accrued_interest"]["status"] != "remove"
                  %button.btn.btn-sm.btn-danger.btn-erase{ data: { id: loan.id } }
                    .fa.fa-times
                    Delete

  
    - @paid_loans.each do |loan|
      - if loan.data["accrued_interest"].present?
        %tr
          %td
            #{loan.pn_number}
          %td
            #{loan.loan_product}
          %td
            #{loan.data["accrued_interest"]["total_accrued_interest"]}
          %td
            #{loan.data["accrued_interest"]["total_accrued_interest_balance"]}
          %td
            #{loan.data.with_indifferent_access[:accrued_interest][:total_accrued_interest].to_f - loan.data.with_indifferent_access[:accrued_interest][:total_accrued_interest_balance].to_f}
          %td
            -if loan.data["accrued_interest"]["status"] == "remove"
              #{loan.data["accrued_interest"]["status"]}
                
            -else
            
              - if loan.data["accrued_interest"]["status"].present?
                #{loan.data["accrued_interest"]["status"]}
              - else
                Active
            

          - if current_user.roles.include?("SBK")
            %td
              -if loan.data["accrued_interest"]["status"] != "remove"
                %button.btn.btn-sm.btn-danger.btn-erase{ data: { id: loan.id } }
                  .fa.fa-times
                  Delete


