%hr
%h6
  Loan Cycles
- if @loan_cycles.present?
  %table.table.table-bordered.table-hover.table-sm
    %thead
      %tr
        %th
          Loan Product
        %th.text-center
          Cycle Count
    %tbody
      - @loan_cycles.each do |o|
        %tr
          %td
            #{LoanProduct.find(o[:loan_product_id]).name}
          %td.text-center
            #{o[:cycle]}

- else
  %p
    No member loan cycle data found.
