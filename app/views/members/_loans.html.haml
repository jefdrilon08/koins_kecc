%h6
  Active Loans
  %small.text-muted
    Entry Point Loan Cycle Count: #{@member.entry_point_loan_cycle_count}

- if @active_loans.any?
  %table.table.table-bordered.table-hover.table-sm
    %thead
      %tr
        %th
          PN Number
        %th
          Loan Product
        %th.text-center
          Cycle 
        %th.text-end
          Total Due
        %th.text-end
          Total Paid
        %th.text-end
          Total Balance
    %tbody
      - @active_loans.each do |loan|
        %tr
          %td
            = link_to loan_path(loan) do
              %strong
                #{loan.pn_number}
          %td.text-muted
            #{loan.loan_product}
          %td.text-center
            #{loan.cycle}
            
          %td.text-end
            %strong
              #{number_to_currency(loan.total_dues, unit: "")}
          %td.text-end
            %strong
              #{number_to_currency(loan.total_paid, unit: "")}
          %td.text-end
            %strong
              #{number_to_currency(loan.total_balance, unit: "")}

  %button#btn-restructure.btn.btn-info.text-white{ data: { "bs-toggle": "modal", "bs-target": "#modal-restructure" } }
    .fa.fa-sync
    Restructure
- else
  %p
    No active loans found.

