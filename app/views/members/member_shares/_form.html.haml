= simple_form_for [@member, @member_share] do |f|
  .form-group
    = f.input :certificate_number, input_html: { class: 'form-control' }
  .form-group
    = f.input :date_of_issue, as: :string, input_html: { class: 'form-control', type: 'date' }
  %hr
  .btn-group
    %button.btn.btn-primary{ type: "submit" }
      .fa.fa-check
      Save
    = link_to member_path(@member), class: 'btn btn-danger' do
      .fa.fa-times
      Cancel
