= simple_form_for [@member, @member_share] do |f|
  .row
    .col-md-6
      .form-group
        = f.input :certificate_for, input_html: { class: 'form-control', id: 'certificate-for' }, as: :select, collection: Settings.organizations, include_blank: false, label: "CERTIFICATE FOR"
  .row
    .col-md-12
      .form-group
        = f.input :certificate_number, input_html: { class: 'form-control', id: 'certificate-number' }
  .row
    .col-md-12    
      .form-group
        = f.input :date_of_issue, as: :string, input_html: { class: 'form-control', type: 'date' , id: 'date-of-issue'}
  .row
    .col-md-12
      .form-group
        = f.input :number_of_shares, as: :string, input_html: { class: 'form-control', type: 'integer' , value: 1}
 
  %hr
  .btn-group
    %button.btn.btn-primary{ type: "submit" }
      .fa.fa-check
      Save
    = link_to member_path(@member), class: 'btn btn-danger' do
      .fa.fa-times
      Cancel