#modal-create-survey.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Create Survey
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Select the survey you want to create
          .form-group
            %label
              Survey:
            = select_tag :survey_id, options_from_collection_for_select(@surveys, :id, :name, @survey.try(:id)), class: "form-control select-select2", id: "select-survey", prompt: "-- SELECT --"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-create-survey.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
