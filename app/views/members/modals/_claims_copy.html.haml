#modal-claims-copy.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Claims Copy
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          .row
            .col
              .form-group
                %label
                  Date of Death:
                = date_field_tag :date_of_death, @date_of_death, class: "form-control", id: "input-date-of-death"     
          .message
      .modal-footer
        .controls
          %button#btn-confirm-claims-copy.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
