#modal-save-form-make-payment.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Save Make Payment
      .modal-body
        .modal-body-content
          .callout.callout-info
            %p
              Are you sure you want to save this Make Payment?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-save-form-make-payment.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel