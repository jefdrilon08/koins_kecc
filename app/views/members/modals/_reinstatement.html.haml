#modal-reinstatement.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Reinstatement
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          .row
            .col
              .form-group
                %label
                  Reinstatement Date:
                = date_field_tag :reinstatement_date, @reinstatement_date, class: "form-control", id: "input-reinstatement-date"      
          .message
      .modal-footer
        .controls
          %button#btn-confirm-reinstatement.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
