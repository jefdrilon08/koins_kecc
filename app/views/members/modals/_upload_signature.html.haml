#modal-upload-signature.modal.fade{:tabindex => "-1"}
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          Upload Signature
      .modal-body
        .modal-body-content
          = file_field_tag :signature, id: "file-signature"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-upload-signature.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
