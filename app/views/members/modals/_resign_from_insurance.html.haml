#modal-resign-from-insurance.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Resignation Date
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          .row
            .col
              .form-group
                %label
                  Resignation Date:
                = date_field_tag :date_resigned, @date_resigned, class: "form-control", id: "input-date-resigned"
          .row
            .col
              .form-group
                %label
                  Reason:
                = text_field_tag :reason, @member.data.with_indifferent_access[:reason], class: "form-control", id: "input-reason"      
          .message
      .modal-footer
        .controls
          %button#btn-confirm-insurance-resign.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
