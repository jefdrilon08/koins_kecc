%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      Clip Claims From
  %li.breadcrumb-item
    .fa.fa-user
    = link_to members_path(@member) do
      #{@member.full_name} 
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to clip_claims_path do
        .fa.fa-arrow-left
        Back to Clip Claims

.container-fluid
  .row
    .col
      .card
        .card-body
          = render partial: "members/clip_claims/form", locals: { clip_claim: @clip_claim }
