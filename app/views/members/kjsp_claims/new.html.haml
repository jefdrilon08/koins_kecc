%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      KJSP Form
  %li.breadcrumb-item
    .fa.fa-user
    = link_to @member.full_name, member_path(@member), target: '_blank'
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to kjsp_claims_path do
        .fa.fa-arrow-left
        Back to Claims

.container-fluid
  .row
    .col
      .card
        .card-body
          = render partial: "members/kjsp_claims/form", locals: { kjsp_claim: @kjsp_claim }
