%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      Claims Form
  %li.breadcrumb-item
    .fa.fa-user
    = link_to @member.full_name, member_path(@member), target: '_blank'
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to claims_path do
        .fa.fa-arrow-left
        Back to Claims

.container-fluid
  .row
    .col
      .card
        .card-body
          = render partial: "members/claims/form", locals: { claim: @claim }
          = render partial: "shared/errors_template"