%ol.breadcrumb
  %li.breadcrumb-item
    = link_to members_path do
      .fa.fa-users
      Members
  %li.breadcrumb-item
    = link_to member_path(@member) do
      .fa.fa-user
      #{@member.full_name}
  %li.breadcrumb-item
    = link_to member_survey_answer_path(@member, @survey_answer) do
      .fa.fa-file
      #{@survey_answer.survey.name}
  %li.breadcrumb-item
    .fa.fa-pencil-alt
    Edit
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
