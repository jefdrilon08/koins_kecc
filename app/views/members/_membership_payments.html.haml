- if membership_payments.size == 0
  %p
    No membership payments for this member
- else
  %table.table.table-bordered.table-sm.table-hover
    %thead
      %tr
        - if current_user.roles.include?("MIS")
          %th
            ID
        %th
          Date Approved
        %th
          Name
        %th
          Type
        %th.text-end
          Amount
        %th.text-center
          Status
        - if current_user.roles.include?("BK") || current_user.roles.include?("SBK") || current_user.roles.include?("MIS")
          %th.text-center
            Actions
    %tbody
      - membership_payments.each do |o|
        %tr
          - if current_user.roles.include?("MIS")
            %td
              #{o.id}
          %td
            #{o.date_paid.strftime("%B %d, %Y")}
          %td
            #{o.membership_name}
          %td
            #{o.membership_type}
          %td.text-end
            #{number_to_currency(o.amount, unit: "")}
          %td.text-center
            #{o.status}
          - if current_user.roles.include?("BK") || current_user.roles.include?("SBK") || current_user.roles.include?("MIS")
            %td.text-center
              = link_to membership_payment_record_path(o), method: :delete, data: { confirm: 'Are you sure?' }, class: 'btn btn-sm btn-danger' do
                .fa.fa-times
