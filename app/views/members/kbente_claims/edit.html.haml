%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      K-Bente Information
  %li.breadcrumb-item
    .fa.fa-user
      Edit Record for: #{link_to @member.full_name, member_path(@member), target: '_blank'}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to kbente_claims_path do
        .fa.fa-arrow-left
        Back to Claims

.container-fluid
  .row
    .col
      .card
        .card-body
          = render partial: "members/kbente_claims/form", locals: { kbente_claim: @kbente_claim }

