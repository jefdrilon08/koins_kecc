- if @data[:resignation_records].present?
  %table.table.table-sm.table-bordered
    %thead
      %tr
        %th
          Date Resigned
        %th
          Type
        %th
          Reason
    %tbody
      - @data[:resignation_records].each do |o|
        %tr
          %td
            #{o[:date_resigned].to_date.strftime("%B %d, %Y")}
          %td
            #{o[:data][:type]}
          %td
            #{o[:data][:reason]}
- else
  %p
    No resignation records
