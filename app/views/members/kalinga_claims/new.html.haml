%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      Kalinga Form
  %li.breadcrumb-item
    .fa.fa-user
    = link_to @member.full_name, member_path(@member), target: '_blank'
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to kalinga_claims_path do
        .fa.fa-arrow-left
        Back to Kalinga

.container-fluid
  .row
    .col
      .card
        .card-body
          = render partial: "members/kalinga_claims/form", locals: { kalinga_claim: @kalinga_claim }
