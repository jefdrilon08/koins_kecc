= form_tag "", method: 'GET' do
  .row
    .col-md-3
      .form-group
        %label
          Start Date
        = text_field_tag :start_date, @start_date, class: 'form-control', type: :date
    .col-md-3
      .form-group
        %label
          End Date
        = text_field_tag :end_date, @end_date, class: 'form-control', type: :date
    .col-md-4
      .form-group
        %label
          Branch
        = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "branch-select", prompt: "-- SELECT --"
    .col-md-2
      .form-group
        %label
          Actions
        = button_tag type: 'submit', class: 'btn btn-info btn-block' do
          .bi.bi-search
