#modal-new.modal.fade
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          New Daily Branch Metric
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Create a new record
          .row
            .col
              .form-group
                %label
                  As Of
                = text_field_tag :as_of, @current_date, class: 'form-control', type: :date, id: "input-as-of"
            .col
              .form-group
                %label
                  Branch
                = select_tag :branch, options_from_collection_for_select(@branches, :id, :name), id: "select-branch", class: "form-control"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
