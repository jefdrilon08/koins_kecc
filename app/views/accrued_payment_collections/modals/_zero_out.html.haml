#modal-zero-out.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Accrued Interest Collection - Zero Out
      .modal-body
        .modal-body-content
          .row
            .col
              .alert.alert-info
                Are you sure you want to zero out this Accrued Interest Collection?
              .message
      .modal-footer
        .controls
          %button#btn-confirm-zero.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
