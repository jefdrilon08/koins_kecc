%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-bill
    Cash Management
  %li.breadcrumb-item
    = link_to savings_insurance_transfer_collections_path do
      .fa.fa-download
      Savings Insurance Transfers
  %li.breadcrumb-item
    #{@savings_insurance_transfer_collection.branch} #{@savings_insurance_transfer_collection.collection_date}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      - if @savings_insurance_transfer_collection.pending?
        = link_to "#", class: 'btn', id: 'btn-approve' do
          .fa.fa-check
          Approve
        = link_to savings_insurance_transfer_collection_path(@savings_insurance_transfer_collection), class: 'btn', method: :delete, data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
