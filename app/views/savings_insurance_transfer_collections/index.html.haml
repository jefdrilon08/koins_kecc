= title
= render partial: "index_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          - if @savings_insurance_transfer_collections.any?
            = render partial: "index_list"
          - else
            %p
              No records found

= render partial: "savings_insurance_transfer_collections/modals/new_transaction"
= render partial: "shared/errors_template"

= javascript_include_tag "savings_insurance_transfer_collections/Index"

:javascript
  $(document).ready(function() {
    var authenticityToken = $("meta[name='csrf-token']").attr('content');

    Index.init({
      authenticityToken: authenticityToken
    });
  });
