#modal-approve-transaction.modal.fade{:tabindex => "-1"}
  .modal-dialog                
    .modal-content             
      .modal-header
        %h3.modal-title        
          Approve MBS Transfer
      .modal-body              
        .modal-body-content    
          .row
            .col               
              .c-callout.c-callout-info       
                Are you sure you want to approve this MBA Transfer?
              .message         
      .modal-footer            
        .controls              
          %button#btn-confirm-process.btn.btn-primary
            .fa.fa-check       
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times       
            Cancel

