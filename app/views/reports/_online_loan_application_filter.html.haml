.row
  .col
    = form_tag "", method: 'GET' do
      .row
        .col-md-3
          .form-group
            %label
              SATO
            = select_tag :branch_select, options_from_collection_for_select(@branches, :id, :name, params[:branch_select]), class: "form-control select-select2", id: "branch-select", prompt: "-- SELECT --"
        .col-md-2
          .form-group
            %label
              Start Date
            = text_field_tag :start_date, params[:start_date], class: 'form-control', type: :date
        .col-md-2
          .form-group
            %label
              End Date
            = text_field_tag :end_date, params[:end_date], class: 'form-control', type: :date
        .col-md-2
          .form-group
            %label
              Status
            = select_tag :status, options_for_select(OnlineApplication::STATS, @status), { prompt: "-- SELECT --", class: "form-control", id: "select-status" }
        .col-md-2
          .form-group
            %label
              Actions
            = button_tag type: 'submit', class: 'btn btn-info btn-block' do
              .bi.bi-search