= form_tag cic_path, html: { novalidate: true }, method: "GET" do
  .row
    .col-sm-3
      .form-group
        %label Provider Code
        = text_field_tag :provider_code, @provider_code, class: "form-control", id: "provider-code"
    .col-sm-3
      .form-group
        %label Start Date
        = text_field_tag :start_date, @start_date, class: "form-control", type: "date", id: "start-date"
    .col-sm-3
      .form-group
        %label End Date
        = text_field_tag :end_date, @end_date, class: "form-control",type: "date", id: "end-date"
    .col-sm-3
      .form-group
        %label Actions
        = link_to "#", id: 'download-btn', class: 'btn btn-primary btn-block' do
          .fa.fa-download
          Download 
