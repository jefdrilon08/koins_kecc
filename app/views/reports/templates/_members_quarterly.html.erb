          <td>{{total_active}}</td>
          <td>{{total_active_inforce}}</td>
          <td>{{total_active_lapsed}}</td>
          <td>{{total_new}}</td>
          <td>{{total_resigned}}</td>
          <td>{{total_female}}</td>
          <td>{{total_male}}</td>
          <td>{{total_with_spouse}}</td>
          <td>{{total_valid_dependent}}</td>
          <td>{{total_single}}</td>
          <td>{{total_married}}</td>
          <td>{{total_maykinakasama}}</td>
          <td>{{total_hiwalay}}</td>
          <td>{{total_biyuda}}</td>
