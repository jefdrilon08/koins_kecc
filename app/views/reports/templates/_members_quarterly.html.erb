<script id="member-quarterly-reports-template" type="x-tmpl-mustache">
  <table class='ui small teal table sticky'>
    <thead>
      <tr>
        <th width='20%'>Branch</th>
        <th width='10%'>Active Members</th>
        <th width='10%'>Active Inforce Members</th>
        <th width='10%'>Active Lapsed Members</th>
        <th width='10%'>New Members</th>
        <th width='10%'>Resigned Members</th>
        <th width='10%'>Female</th>
        <th width='10%'>Male</th>
        <th width='10%'>Spouse</th>
