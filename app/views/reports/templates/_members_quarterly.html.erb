          <td>{{active_count}}</td>
          <td>{{active_inforce_count}}</td>
          <td>{{active_lapsed_count}}</td>
          <td>{{new_count}}</td>
          <td>{{resigned_count}}</td>
          <td>{{female_count}}</td>
          <td>{{male_count}}</td>
          <td>{{member_with_spouse_count}}</td>
          <td>{{valid_dependent_count}}</td>
          <td>{{single}}</td>
          <td>{{married}}</td>
          <td>{{maykinakasama}}</td>
          <td>{{hiwalay}}</td>
          <td>{{biyuda}}</td>
        </tr>
      {{/members}}
