= form_tag monthly_collection_path, html: { novalidate: true }, method: "GET" do
  .row
    .col-sm-3
      .form-group
        %label Branch
        = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), prompt: "-- SELECT --",class: "form-control select-select2", id: "branch-select"
    .col-sm-3
      .form-group
        %label Start Date
        = text_field_tag :start_date, current_month_start, class: "form-control", type: "date", id: "start-date"
    .col-sm-3
      .form-group
        %label End Date
        = text_field_tag :end_date, current_month_end, class: "form-control",type: "date", id: "end-date"
    .col-sm-3
      .form-group
        %label Actions
        = link_to "#", id: 'download-btn', class: 'btn btn-primary btn-block' do
          .fa.fa-download
          Download 

= javascript_include_tag "reports/MonthlyCollectionReport"

:javascript
  $(document).ready(function() {
    MonthlyCollectionReport.init();
  });


