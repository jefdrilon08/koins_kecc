#modal-assign-officer.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Assign Officer
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Change this center's officer
          .message
          .row
            .col
              .form-group
                %label
                  Select Officer
                = select_tag :officer, options_from_collection_for_select(User.order("last_name DESC"), :id, :to_s, @center.user_id), class: "form-control select-select2", id: "select-officer"
      .modal-footer
        .controls
          %button#btn-confirm-assign-officer.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
