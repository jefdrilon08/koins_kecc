.card
  .card-body
    %center
      %h4
        #{@center.name}
        %br
        %small.text-muted
          #{@center.short_name}
    %table.table.table-sm
      %tr
        %th
          Branch
        %td.text-muted.text-end
          = link_to administration_branch_path(@center.branch) do
            #{@center.branch.name}
      
      %tr
        %th
          Meeting Day
        %td.text-muted.text-end
          #{@center.meeting_day_display}

      %tr
        %th
          Socioeconomic Officer
        %td.text-muted.text-end
          #{@center.user}
    %hr
    #btn-assign-officer.btn.btn-block.btn-info.text-white
      .fa.fa-check
      Assign Officer
