.table-responsive
  %table.table.table-bordered.table-sm
    %thead
      %tr
        %th
          ID Number
        %th
          Name
        %th
          Access Token
    %tbody
      - @registered_members.each do |m|
        %tr
          %td
            = link_to member_path(m) do
              #{m.identification_number}
          %td
            = link_to member_path(m) do
              #{m.full_name}
          %td
            %code
              #{m.access_token}
