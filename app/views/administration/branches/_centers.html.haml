.table-responsive
  %table.table-bordered.table.table-sm
    %thead
      %tr
        %th 
          Name
        %th
          SO
        %th
          %center
            Meeting Day
        %th
          %center
            \# Members
    %tbody
      - @centers.each do |center|
        %tr
          %td
            = link_to administration_center_path(center.id), target: '_blank' do
              %strong
                = center.name
                %br
                %small
                  #{center.id}
          %td
            #{center.user}
          %td
            %center
              %small
                #{center.meeting_day_display}
          %td
            %center
              #{center.members.active.count}
