%ol.breadcrumb
  %li.breadcrumb-item
    = link_to administration_project_type_categories_path do
      .fa.fa-file
      Project Type Categories
  %li.breadcrumb-item
    .fa.fa-file
    #{@project_type_category}

  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to edit_administration_project_type_category_path(@project_type_category), class: 'btn' do
        .fa.fa-pencil-alt
        Edit
      = link_to administration_project_type_category_path(@project_type_category), class: 'btn', method: :delete, data: { confirm: "Are you sure?" } do
        .fa.fa-times
        Delete
