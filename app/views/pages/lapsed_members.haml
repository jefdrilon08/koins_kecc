= title

%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
    Microinsurance
  %li.breadcrumb-item
    .fa.fa-users
    Lapsed Members
.container-fluid
  .row
    .col
      .card
        .card-body
          .errors_template
            #filter
              = form_tag lapsed_members_path, html: { novalidate: true }, method: "GET", defaults: { wrapper_html: { class: 'form-group' }, input_html: { class: 'form-control simple_form' } } do
                .row
                  .col-md-6
                    .form-group
                      %label Branch 
                      = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "branch-select", prompt: "-- SELECT --"
                  .col-md-6
                    .form-group
                      %label Actions
                      %br
                      .ui.large.buttons
                        = button_tag :submit, class: 'btn btn-primary' do
                          .fa.fa-search
                          Search
            %table#data-table.display.table.table-bordered.table-hover.table-sm
              %thead
                %tr
                  %th
                    Branch
                  %th
                    Center
                  %th
                    ID Number
                  %th
                    Name
                  %th
                    Recognition Date
                  %th
                    Lenght of Stay
                  %th
                    Member Type
                  %th
                    Status
                  %th
                    Insurance Status
                  %th
                    Date of Birth
                  %th
                    Age
                  %th
                    LIFE
                  %th
                    RF  
              %tbody
                - @members.find_each(batch_size: 1000) do |m|
                  %tr
                    %td 
                      #{m.branch.name}
                    %td
                      #{m.center.name}
                    %td 
                      #{m.identification_number}
                    %td 
                      #{m.full_name}
                    %td
                      #{m.data.with_indifferent_access[:recognition_date]}
                    %td 
                      #{m.length_of_stay}
                    %td
                      #{m.member_type}
                    %td
                      #{m.status}
                    %td
                      #{m.insurance_status} 
                    %td 
                      #{m.date_of_birth}
                    %td
                      #{m.age}
                    %td
                      #{m.lif_amount}
                    %td
                      #{m.rf_amount}

