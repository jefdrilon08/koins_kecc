= title

%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-tachometer-alt
    Operations
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to member_form_path, class: "btn" do
        .fa.fa-plus
        New Member
      = link_to members_path(status: "pending"), class: "btn" do
        .fa.fa-arrow-right
        Pending Records (#{@pending_members_count})

.container-fluid
  .row
    .col
      .card
        .card-body
          #dashboard-content

#parameters{ data: { username: current_user.username, roles: current_user.roles } }

- if microloans?
  = javascript_include_tag "DashboardMain.min.react"
- elsif microinsurance?
  = javascript_include_tag "DashboardMainMii.min.react"
