%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-tachometer-alt
    Validations Report
.container-fluid
  .row
    .col
      .card
        .card-body
          %h5
            Exports Page
          #filter  
          = form_tag export_tools_path, html: { novalidate: true }, method: "GET" do
            .row
              .col-md-3
                .form-group
                  %label Branch
                  = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch_id), class: "form-control select-select2", id: "branch-select", prompt: "-- SELECT --"
              .col-md-3
                .form-group
                  %label Status
                  = select_tag :status, options_for_select(MemberAccountValidation::STATUSES, @status), class: "form-control select-select2", id: "status", prompt: "-- SELECT --"
              .col-md-2
                .form-group
                  %label Start Date
                  = date_field_tag :start_date, @start_date, class: "form-control", value: Date.today.beginning_of_month, id: "start-date"
              .col-md-2
                .form-group
                  %label End Date
                  = date_field_tag :end_date, @end_date, class: "form-control", value: Date.today.end_of_month, id: "end-date"
              .col-md-2
                .form-group
                  %br
                  %label
                  = link_to "#", id: 'download-btn', class: "btn btn-primary" do
                    .fa.fa-download
                    Download Excel

= javascript_include_tag "member_account_validation/ValidationsReport"

:javascript
  $(document).ready(function() {
    var authenticityToken = $("meta[name='csrf-token']").attr('content');

    ValidationsReport.init({
      authenticityToken: authenticityToken
    });
  })
