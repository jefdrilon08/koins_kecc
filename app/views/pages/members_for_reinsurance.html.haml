= title
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            %table#data-table.display.table.table-bordered.table-hover.table-sm
              %thead
                %tr
                  %th
                    Name
                  %th
                    Member Type
                  %th
                    Date of Birth
                  %th
                    Age
                  %th
                    Branch
                  %th
                    Center
              %tbody
                - @members.each do |m|
                  %tr
                    %td
                      = link_to member_path(m) do 
                        #{m.full_name}
                    %td
                      #{m.member_type}
                    %td 
                      #{m.date_of_birth}
                    %td
                      #{m.age}
                    %td 
                      #{m.branch.name}
                    %td
                      #{m.center.name}

