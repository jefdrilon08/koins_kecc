= form_tag "", method: 'GET' do
  .row
    .col-md-3.col-xs-12
      .form-group
        %label
          Query
        = text_field_tag :q, @q, class: 'form-control', placeholder: 'Name'
    .col-md-3.col-xs-12
      .form-group
        %label
          Status
        = select_tag :status, options_for_select(OnlineApplication::STATUSES, @status), class: "form-control select-select2", id: "status-select", prompt: "-- SELECT --"
    .col-md-3.col-xs-12
      .form-group
        %label
          Branch
        = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control", prompt: "-- SELECT --"
    .col-md-3.col-xs-12
      .form-group
        %label
          Actions
        .form-group
          .btn-group
            = button_tag type: 'submit', class: 'btn btn-primary btn-block' do
              .bi.bi-search
