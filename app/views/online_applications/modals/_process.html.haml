#modal-process.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Process Application
      .modal-body
        .modal-body-content
          .alert.alert-info
            %p
              Are you sure you want to process this application?
          .row
            .col-md-6.col-xs-12
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @online_application.branch_id), class: "form-control select-select2", id: "select-branch", prompt: "-- SELECT --"
            .col-md-6.col-xs-12
              .form-group
                %label
                  Center
                = select_tag :center_id, options_for_select([]), class: "form-control select-select2", id: "select-center", prompt: "-- SELECT --"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-process.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
