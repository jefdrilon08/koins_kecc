#modal-verify.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Verify Application
      .modal-body
        .modal-body-content
          .alert.alert-info
            %p
              Are you sure you want to verify this application?
          .message
          .row
            .col
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @online_application.branch_id), class: "form-control select-select2", id: "select-verify-branch"
      .modal-footer
        .controls
          %button#btn-confirm-verify.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
