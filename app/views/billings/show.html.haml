= title @billing.id
= render partial: "show_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          - if @billing.pending?
            .callout.callout-info
              %p
                Pindutin ang amount upang baguhin ito.
          - elsif @billing.processing?
            .callout.callout-danger
              %p
                This billing is still being processed.
          - elsif @billing.approved?
            .callout.callout-success
              %p
                This billing has been approved on #{@billing.date_approved.strftime("%b %d, %Y")}

          - if !@billing.checked?
            .callout.callout-danger
              This billing has not been checked yet.
          - else
            .callout.callout-info
              Checked By: #{@billing.checked_by}

          %h5
            Billing for #{@billing.branch} / #{@billing.center} - #{@billing.collection_date.strftime("%b %d, %Y")} #{@billing.approved? ? "(Approved on #{@billing.date_approved.strftime("%b %d, %Y")})" : ""}

          #billing-content

          - if debug?
            %pre
              %code
                #{JSON.pretty_generate(JSON.parse(@billing.to_json))}
          %hr
          = render partial: "shared/activity_logs", locals: { activity_logs: @activity_logs }

= render partial: "shared/modals/print"
= render partial: "billings/modals/approve"
= render partial: "billings/modals/check"
= render partial: "billings/modals/zero_out"
= render partial: "templates/error_list"

#parameters{ data: { id: @billing.id } }

= javascript_include_tag "BillingUI.min.react"
= javascript_include_tag "billings/Show"

:javascript
  $(document).ready(function() {
    var $parameters       = $("#parameters");
    var billingId         = $parameters.data('id');
    var authenticityToken = $("meta[name='csrf-token']").attr('content');

    Show.init({
      billingId: billingId, 
      authenticityToken: authenticityToken
    });
  });
