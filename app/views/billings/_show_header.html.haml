%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-bill
    Cash Management
  %li.breadcrumb-item
    = link_to billings_path do
      .fa.fa-download
      Billings
  %li.breadcrumb-item
    Billing: #{@billing.id}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      - if @billing.pending?
        = link_to billing_path(@billing), class: 'btn', method: :delete, data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
