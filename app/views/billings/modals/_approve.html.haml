#modal-approve.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Approve Billing
      .modal-body
        .modal-body-content
          .callout.callout-info
            %p
              Are you sure you want to approve this billing? 
            %p
              Approval date is 
              %span
                %strong
                  #{@current_date.strftime("%b %d, %Y")}
          .message
      .modal-footer
        .controls
          %button#btn-confirm-approve.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
