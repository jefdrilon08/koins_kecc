#modal-uncheck.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Uncheck Billing
      .modal-body
        .modal-body-content
          .callout.callout-info
            %p
              Are you sure you want to uncheck this billing?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-uncheck.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
