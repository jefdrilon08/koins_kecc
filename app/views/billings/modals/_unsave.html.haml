#modal-unsave.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Unsave Billing
      .modal-body
        .modal-body-content
          .callout.callout-info
            %p
              Are you sure you want to unsave this billing?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-unsave.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
