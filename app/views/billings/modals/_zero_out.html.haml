#modal-zero-out.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Zero Out
      .modal-body
        .modal-body-content
          .callout.callout-info
            %p
              Are you sure you want to zero out this billing?
          .message
        .modal-body-content
          .callout.callout-info
            .form-group
              .form-check
                %input#check-special-report.form-check-input{:type => "checkbox"}/
                %label.form-check-label{:for => "flexCheckDefault"}
                  It is Special Report?
      .modal-footer
        .controls
          %button#btn-confirm-zero-out.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
