#modal-zero-out.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Zero Out
      .modal-body
        .modal-body-content
          .callout.callout-info
            %p
              Are you sure you want to zero out this billing?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-zero-out.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
