.row
  .col
    .card
      .card-body
        %h5
          Billing for Involuntary #{@data_store.meta["branch_name"]}

        - if @data_store["status"] == "pending"
          = render partial: "form_add"

        - if @data_view.any?
          = render partial: "members_table"
        -else
          %p
            No records found
        %hr

        %h4
          Accounting Entry
        = render partial: "accounting_entry_display", locals: { accounting_entry: @accounting_entry }


        

= render partial: "billing_for_involuntary/modals/update_transaction"
= render partial: "billing_for_involuntary/modals/view_details"
= render partial: "billing_for_writeoff_collections/modals/approve_transaction"         
