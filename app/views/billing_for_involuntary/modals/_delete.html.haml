#modal-delete.modal.fade
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          Involuntary Collections
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          .row
            .col
              %p Delete Member
          .message
      .modal-footer
        .controls
          %button#btn-confirm-delete.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
