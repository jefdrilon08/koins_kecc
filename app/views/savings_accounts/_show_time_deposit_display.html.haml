- if @pending_requests.size > 0
  %h4
    Withdrawal Request
  = render partial: "savings_accounts/time_deposit/pending_requests"

  - if params[:debug].present?
    %pre
      #{JSON.pretty_generate(@pending_requests)}
- else
  No current pending withdrawal requests.
%hr
- if @approved_requests.size > 0
  %h4
    Approved Withdrawals
  = render partial: "savings_accounts/time_deposit/approved_requests"
- else
  No current approved withdrawals.
