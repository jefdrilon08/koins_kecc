%table.table.table-bordered.table-sm
  %thead
    %tr
      %th
        Account
      %th
        Branch
      %th.text-center
        Type
      %th.text-end
        Balance
  %tbody
    - @savings_accounts.each do |o|
      %tr
        %th
          = link_to savings_account_path(o) do
            #{o.member.full_name}
        %td
          #{o.branch}
        %td.text-center
          %small
            #{o.account_subtype}
        %th.text-end
          #{number_to_currency(o.balance, unit: '')}
