%table.table.table-sm.table-bordered
  %tr
    %th.text-end
      Amount Locked
    %th
      Start Date
    %th
      Date Renewed
    %th
      Interest Rate
    %th.text-center
      Num Days
    %th.text-end
      Interest Garnered
  - @autorenewals.each do |o|
    %tr
      %td.text-end
        #{number_to_currency(o.data["balance"], unit: '')}
      %td
        #{o.data["start_date"].to_date.strftime("%B %d, %Y")}
      %td
        #{o.data["end_date"].to_date.strftime("%B %d, %Y")}
      %td
        #{o.data["lock_in_period"]["interest_rate"]}
      %td.text-center
        #{o.data["lock_in_period"]["num_days"]}
      %td.text-end
        #{number_to_currency(o.data["lock_in_period"]["expected_interest"], unit: '')}
