#modal-approve-withdrawal-request.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Approve Withdrawal Request
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Are you sure you want to approve this request?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-approve-withdrawal-request.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
