#modal-request-time-deposit-withdrawal.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Request Time Deposit Withdrawal
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Are you sure you want to request time deposit withdrawal?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-request-time-deposit-withdrawal.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
