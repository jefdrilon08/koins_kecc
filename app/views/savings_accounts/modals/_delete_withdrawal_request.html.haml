#modal-delete-withdrawal-request.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Delete Withdrawal Request
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-danger
            Are you sure you want to delete this request?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-delete-withdrawal-request.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
