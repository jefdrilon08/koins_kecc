#modal-sync-maintaining-balance.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Sync Maintaining Balance
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Modify this account's maintaining balance
          = number_field_tag :maintaining_balance, @savings_account.maintaining_balance, class: 'form-control', id: 'input-maintaining-balance'
          .message
      .modal-footer
        .controls
          %button#btn-confirm-sync-maintaining-balance.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
