= title @savings_account.id
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            = render partial: "show_details"
            = paginate @account_transactions
            - if @savings_account.time_deposit?
              = render partial: "show_time_deposit_actions"
              = render partial: "show_time_deposit_display"

= render partial: "savings_accounts/modals/sync_maintaining_balance"
= render partial: "savings_accounts/modals/request_time_deposit_withdrawal"
= render partial: "savings_accounts/modals/delete_withdrawal_request"
= render partial: "savings_accounts/modals/approve_withdrawal_request"
= render partial: "shared/modals/print"
= render partial: "templates/error_list"
