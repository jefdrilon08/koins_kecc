= title @time_deposit_collection.id
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            - if @time_deposit_collection.pending?
              .callout.callout-info
                %p
                  Pindutin ang amount upang baguhin ito.
            %h5
              Deposit Collection for #{@time_deposit_collection.branch} / #{@time_deposit_collection.center} - #{@time_deposit_collection.collection_date.strftime("%b %d, %Y")}

            #time-deposit-collection-content

            #settings
              .row
                .col-md-6.col-xs-12
                  %h5
                    Accounting Entry Settings
                  .card
                    .card-body
                      %p
                        Currently book: #{@time_deposit_collection.book}
                      .row
                        .col-md-8.col-xs-12
                          = select_tag :book, options_for_select(["CRB", "JVB"], @time_deposit_collection.book), class: "form-control select-select2", id: "select-book"
                        .col-md-4.col-xs-12
                          #btn-confirm-book.btn.btn-block.btn-warning
                            .fa.fa-sync
                            Use Book
                      .message
                .col-md-6.col-xs-12
                  %h5
                    Cash Management Template
                  .card
                    .card-body
                      %p
                        Currently being used: #{@time_deposit_collection.cash_management_template}
                      .row
                        .col-md-8.col-xs-12
                          = select_tag :cash_management_template, options_for_select(cash_management_templates, @time_deposit_collection.cash_management_template), class: "form-control select-select2", id: "select-cash-management-template", prompt: "-- SELECT --"
                        .col-md-4.col-xs-12
                          #btn-confirm-cash-management-template.btn.btn-block.btn-warning
                            .fa.fa-sync
                            Use Template
                      .message

            - if debug?
              %pre
                %code
                  #{JSON.pretty_generate(JSON.parse(@time_deposit_collection.to_json))}

= render partial: "shared/modals/print"
= render partial: "time_deposit_collections/modals/approve"
= render partial: "templates/error_list"

#parameters{ data: { id: @time_deposit_collection.id, controller: "#{params[:controller]}", action: "#{params[:action]}" } }
