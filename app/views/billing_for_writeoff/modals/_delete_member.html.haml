#modal-delete-member.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Delete Member
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Are you sure you want to delete this Member 
            %span.display-member 
            with Loan Product
            %span.display-loan-product-name
            ?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-delete-member.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
