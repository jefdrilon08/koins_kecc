.row
  .col-md-4.col-xs-12
    .form-group
      %label
        Member
      = select_tag :member, options_for_select(@members.map{ |o| ["#{o[:last_name]}, #{o[:first_name]} (#{o[:center][:name]})", o[:id]] }), class: "form-control select-select2", id: "select-member", prompt: "-- SELECT --"
  .col-md-3.col-xs-12
    .form-group
      %label
        Loan Product
      = select_tag :account, options_for_select(@loans.map{|o| ["#{o[:name]}", o[:id]]}), class: "form-control select-select2", id: "select-loan"
  .col-md-3.col-xs-12
    .form-group
      %label
        Amount
      = number_field_tag :amount, 0.00, class: "form-control", id: "input-amount"
  .col-md-2.col-xs-12
    .form-group
      %label
        Actions
      #btn-add.btn.btn-block.btn-success
        .fa.fa-plus
        Add
