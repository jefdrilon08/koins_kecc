%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-bill
    Cash Management
  %li.breadcrumb-item
    = link_to membership_payment_collections_path do
      .fa.fa-download
      Membership Payments
  %li.breadcrumb-item
    Membership Payment: #{@membership_payment_collection.id}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      - if @membership_payment_collection.pending?
        = link_to "#", class: 'btn', id: 'btn-approve' do
          .fa.fa-check
          Approve
        = link_to membership_payment_collection_path(@membership_payment_collection), class: 'btn', method: :delete, data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
