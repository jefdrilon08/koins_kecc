%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      HIIP
  %li.breadcrumb-item
    .fa.fa-user
    = link_to "#{@hiip_claim.member.full_name}", member_path(@hiip_claim.member), target: "_blank"
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to edit_member_hiip_claim_path(@hiip_claim.member, @hiip_claim), class: 'btn btn-app' do
        %i.fa.fa-edit
        Edit
    .btn-group 
      = link_to hiip_claim_path(@hiip_claim), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-app" do
        %i.fa.fa-times
        Delete
    .btn-group    
      = link_to hiip_claim_hiip_claim_validation_pdf_path(@hiip_claim), target: "_blank", class: "btn btn-app" do
        .fa.fa-download
        Validation PDF
    .btn-group    
      = link_to hiip_claim_hiip_claim_loa_pdf_path(@hiip_claim), target: "_blank", class: "btn btn-app" do
        .fa.fa-download
        LOA 
    .btn-group
      = link_to hiip_claims_path do
        .fa.fa-arrow-left
        Back to HIIP