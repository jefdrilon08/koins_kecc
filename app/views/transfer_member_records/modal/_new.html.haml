#modal-new.modal.fade{:tabindex => "-1"}
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          New Transfer Member
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          NOTE! GERALD POGI ONLY!
          .row
            .col
              .form-group
                %label
                  Select Branch:
                = select_tag :branch, options_from_collection_for_select(@branches, :id, :name), id: "select-branch", class: "form-control"
            .col
              .form-group
                %label
                  Transfer to: 
                = select_tag :branch_to_transfer, options_from_collection_for_select(@branches, :id, :name), id: "select-branch-to-transfer", class: "form-control"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
