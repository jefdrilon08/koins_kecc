:css
  @page { size: landscape; margin: 15px;}

  table {
    font-size: 0.6em;
  }

%small
  %strong
    #{Settings.company_name}
    %br
    #{Settings.company_address}
    %br
    VAT Registration Tin Number: #{Settings.company_tin_number}
    %br
    #{@billing[:center]} / #{@billing[:branch]}
    %br
    Billing: #{@billing[:collection_date].to_date.strftime("%B %d, %Y")}


- billing_total_cp    = 0.00
- billing_grand_total = 0.00
%table.table.table-bordered.table-sm
  %thead
    %tr
      %th{ width: "2%" }
        Att.
      %th{ width: "10%" }
        Member
      - @billing[:data][:totals].each do |t|
        %th
          #{t[:key]}
      %th
        CP
      %th
        TOTAL
  %tbody
    - @billing[:data][:records].each do |r|
      - member_total_cp     = 0.00
      - member_grand_total  = 0.00

      %tr
        %td
        %td
          #{r[:member][:full_name].truncate(20)}
        - r[:records].each do |rr|
          - if rr[:record_type] == "WP"
            - billing_grand_total += rr[:amount].to_f
            - member_grand_total += rr[:amount].to_f
          - else
            - billing_grand_total += rr[:amount].to_f
            - billing_total_cp += rr[:amount].to_f
            - member_grand_total += rr[:amount].to_f
            - member_total_cp += rr[:amount].to_f
          %td
            #{number_to_currency(rr[:amount], unit: "")}
        %td
          #{number_to_currency(member_total_cp, unit: "")}
        %td
          #{number_to_currency(member_grand_total, unit: "")}
  %tr
    %th{ width: "2%" }
    %th{ width: "10%" }
      TOTAL
    - @billing[:data][:totals].each do |t|
      %th
        #{number_to_currency(t[:amount], unit: "")}
    %th
      #{number_to_currency(billing_total_cp, unit: "")}
    %th
      #{number_to_currency(billing_grand_total, unit: "")}

%br
%br
.row
  .col
    %strong
      Prepared By:
    %br
    #{@billing[:prepared_by]}
  .col
    %strong
      Collected By:
    %br
    #{@billing[:collected_by]}
  .col
    %strong
      Checked By:
    %br
    #{@billing[:checked_by]}
  .col
    %strong
      Encoded By:
    %br
    #{@billing[:prepared_by]}
  .col
    %strong
      Posted By:
    %br
    #{@billing[:approved_by]}

:javascript
  window.print();
