:css
  @page { size: landscape; margin: 15px;}

  table {
    font-size: 0.8em;
  }

%small
  %strong
    #{Settings.company_name}
    %br
    #{Settings.company_address}
    %br
    VAT Registration Tin Number: #{Settings.company_tin_number}
    %br
    #{@accrued_billing[:center]} / #{@accrued_billing[:branch]}
    %br
    Accrued Billing: #{@accrued_billing[:collection_date].to_date.strftime("%B %d, %Y")}
    %br

%table.table.table-bordered.table-sm
  %thead
    %tr
      %th{width: "15%"}
        Member
      - @accrued_billing[:data].data['headers'].each do |hd|
        %th{ width: "10%" }
          #{hd['name']}
      %th{ width: "10%" }
        Cash Payment
      %th{ width: "10%" }
        TOTAL
  %tbody
    - @accrued_billing[:data].data['member_data'].each do |md|
      %tr
        %td
          #{md['name']}
        - md['loan_data'].each do |ld|
          %td{:align=>"right"}
            - if ld['amount'] != 'false'
              #{number_to_currency(ld['amount'], unit: '')}
        %td{:align=>"right"}
          #{number_to_currency(md['total_cp'], unit: '')}
        %td{:align=>"right"}
          #{number_to_currency(md['total_payment'], unit: '')}
  %thead
    %tr
      %th
        TOTAL
      - @accrued_billing[:data].data['headers'].each do |hders|
        %td.text-right
          %strong
            #{hders['interest_receivable_amount']}
      %td.text-right
        %strong
          #{number_to_currency(@accrued_billing[:data].data['total_cash_payment'] , unit: '')}
      %td.text-right
        %strong
          #{number_to_currency(@accrued_billing[:data].data['total_payment'] , unit: '')}
 
%br
