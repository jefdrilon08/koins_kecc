      %br
        %span
          %var 4
          %sup th
          Floor KMBA Members Center Building
      %br
        %span
          Telephone Numbers: (632) 8442-9607 or 5310-2470 / Fax Number: 
        %br
          (632) 8442-9607 loc. 204
      %br
        %span
          %b
            CDA REG. NO.: 9520-1016000000028521
      %br
        %span
          %b
            CIN: 16201628521


%strong{style: "font-size: 16px"}
  %center
    Involuntary Members Master List

%br
%br
%table.table.table-bordered.table-sm
  %thead
    %tr
      %th
      %th{ width: "25%" }
        Identification Number
      %th.text-center
        Member Name
      %th.text-center
        Center
      %th.text-center
        Release Date of Letter
  %tbody
    -@data[:records].each_with_index do |rec, index|
      %tr
        %td
          #{index+1}
        %td.text-center
          #{rec[:identification_number]}
        %td.text-center
          #{rec[:member_name]}
        %td.text-center
          #{rec[:center]}
        %td.text-center