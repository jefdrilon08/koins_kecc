:css
  table {
    font-size: 0.9em;
  }

%small
  %strong
    #{Settings.company_name}
    %br
    #{Settings.company_address}
    %br
    VAT Registration Tin Number: #{Settings.company_tin_number}
    %br
    #{@general_ledger[:branch][:name]}
    %br
    General Ledger from #{@general_ledger[:start_date].to_date.strftime("%B %d, %Y")} to #{@general_ledger[:end_date].to_date.strftime("%B %d, %Y")}

%hr

- @general_ledger[:entries].each do |entry|
  - current_dr_sum  = 0.00
  - current_cr_sum  = 0.00

  %table.table.table-bordered.table-sm
    %thead
      %tr
        %th{ colspan: 2 }
          #{entry[:accounting_code_name]}
        %th
          Book
        %th
        %th.text-right
          Debit
        %th.text-right
          Credit
        %th.text-right
          #{number_to_currency(entry[:beginnin_balance], unit: '')}
    %tbody
      - entry[:entries].each do |o|
        - current_dr_sum += o[:dr_amount].to_f.round(2)
        - current_cr_sum += o[:cr_amount].to_f.round(2)
        
        %tr
          %td.text-center{ width: "8%" }
            %small
              #{o[:date_posted]}
          %td{ width: "14%" }
            #{o[:reference_number]}
          %td{ width: "2%" }
            #{o[:book]}
          %td{ width: "50%" }
            #{o[:particular]}
          %td.text-right{ width: "8%" }
            #{number_to_currency(o[:dr_amount], unit: '')}
          %td.text-right{ width: "8%" }
            #{number_to_currency(o[:cr_amount], unit: '')}
          %td.text-right{ width: "8%" }
            #{number_to_currency(o[:running_balance], unit: '')}

    %tfoot
      %tr
        %th{ colspan: 4 }
          Ending for #{entry[:accounting_code_name]}
        %th.text-right
          #{number_to_currency(current_dr_sum, unit: '')}
        %th.text-right
          #{number_to_currency(current_cr_sum, unit: '')}
        %th.text-right
          #{number_to_currency(entry[:ending_balance], unit: '')}

:javascript
  window.print();
