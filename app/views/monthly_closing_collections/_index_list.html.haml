%table.table.table-sm.table-bordered.table-hover
  %thead
    %tr
      %th
        Branch
      %th
        Account
      %th
        Closing Date
      %th
        Closed At
      %th.text-center
        Status
  %tbody
    - @monthly_closing_collections.each do |o|
      %tr
        %td
          = link_to monthly_closing_collection_path(o) do
            %strong
              #{o.branch}
        %td
          #{o.account_subtype}
        %td
          %small
            #{o.closing_date}
        %td
          %small
            #{o.closed_at}
        %td.text-center
          - if o.pending?
            .badge.badge-warning
              Pending
          - elsif o.processing?
            .badge.badge-info
              Processing
          - elsif o.approved?
            .badge.badge-success
              Approved
          - elsif o.error?
            .badge.badge-danger
              Error
