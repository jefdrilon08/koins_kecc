= render partial: "show_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          - if @monthly_closing_collection.error?
            = render partial: "error_page"
          - else
            - if debug?
              %pre
                #{JSON.pretty_generate(JSON.parse(@monthly_closing_collection.data.to_json))}
            #content

= render partial: "monthly_closing_collections/modals/update"
= render partial: "templates/error_list"

#parameters{ data: { id: "#{@monthly_closing_collection.id}" } }

= javascript_include_tag "monthly_closing_collections/Show.js"
= javascript_include_tag "MonthlyClosingCollectionShow.min.react.js"

:javascript
  $(document).ready(function() {
    var authenticityToken = $("meta[name='csrf-token']").attr('content');
    var id                = $("#parameters").data('id');

    Show.init({
      id: id,
      authenticityToken: authenticityToken
    });
  });
