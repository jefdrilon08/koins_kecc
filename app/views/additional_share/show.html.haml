.row
  .col
    .card
      .card-body
        %h5
          Additional Share Capital for #{@data_store.meta["branch_name"]} /
          #{@data_store.meta["center_name"]} - 
          #{@data_store.meta["transaction_date"]}
          
          - if @data_store["status"] == "pending"
            = render partial: "form_add"
          - if @data_view.any?
            = render partial: "members_table"
          -else
            %p
              No records found
        %hr

        %h4
          Accounting Entry
        = render partial: "accounting_entry_display", locals: { accounting_entry: @accounting_entry }


= render partial: "additional_share/modals/update_transaction" 
= render partial: "additional_share/modals/approve_transaction" 
= render partial: "additional_share/modals/delete_member"
