= render partial: "show_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          #content-status
          %table.table.table-hover.table-sm.table-bordered
            %thead
              %tr
                - if current_user.roles.include?("MIS")
                  %th
                %th
                  %center
                    Date
                %th
                  %center
                    Type
                %th.text-right
                  Beginning Balance
                %th.text-right
                  Amount
                %th.text-right
                  Ending Balance
            %tbody
              - @account_transactions.each do |o|
                %tr
                  - if current_user.roles.include?("MIS")
                    %td
                      %small
                        #{o.id}
                  %td
                    %center
                      %small
                        #{o.transacted_at.localtime.strftime("%B %d, %Y %H:%M")}
                  %td
                    %center
                      - if o.deposit?
                        - if o.interest?
                          .badge.badge-info
                            .fa.fa-plus
                            Interest
                        - else
                          .badge.badge-success
                            .fa.fa-download
                            Deposit
                      - elsif o.withdraw?
                        .badge.badge-danger
                          .fa.fa-upload
                          Withdraw
                  %td.text-right.text-muted
                    #{number_to_currency(o.data["beginning_balance"], unit: "")}
                  %td.text-right
                    #{number_to_currency(o.amount, unit: "")}
                  %td.text-right.text-muted
                    #{number_to_currency(o.data["ending_balance"], unit: "")}

#parameters{ data: { member_account_id: @insurance_account.id}}

= javascript_include_tag "MemberAccountInsuranceStatus.min.react.js"