                        - else
                          .badge.bg-success
                            .fa.fa-download
                            Deposit
                      - elsif o.withdraw?
                        .badge.bg-danger
                          .fa.fa-upload
                          Withdraw
                  %td.text-end
                    #{number_to_currency(o.amount, unit: "")}
        - elsif @insurance_account.account_subtype == Settings.kalinga
