%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-bill
    Cash Management
  %li.breadcrumb-item
    = link_to deposit_collections_path do
      .fa.fa-download
      Deposits
  %li.breadcrumb-item
    Deposit: #{@deposit_collection.id}
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to "#", class: 'btn', id: 'btn-print-accounting-entry' do
        .fa.fa-print
        Print Accounting Entry
      = link_to "#", class: 'btn', id: 'btn-print' do
        .fa.fa-print
        Print
      - if @deposit_collection.pending?
        = link_to "#", class: 'btn', id: 'btn-load-branch' do
          .fa.fa-sync
          Load Branch
        = link_to "#", class: 'btn', id: 'btn-load-center' do
          .fa.fa-sync
          Load Center
      - if @deposit_collection.pending? && (current_user.roles.include?("MIS") || current_user.roles.include?("BK") || current_user.roles.include?("SBK") || current_user.roles.include?("REMOTE-BK") || current_user.roles.include?("REMOTE-FM"))
        = link_to deposit_collection_path(@deposit_collection), class: 'btn', method: :delete, data: { confirm: "Are you sure?" } do
          .fa.fa-times
          Delete
      - if @deposit_collection.pending? && !@deposit_collection.finalized? && (current_user.roles.include?("REMOTE-BK") || current_user.roles.include?("MIS") || current_user.roles.include?("REMOTE-FM"))
        = link_to "#", class: 'btn', id: 'btn-finalize' do
          .fa.fa-check
          Finalize
      - if @deposit_collection.pending? && (current_user.roles.include?("MIS") || current_user.roles.include?("BK") || current_user.roles.include?("SBK"))    
        - if Settings.activate_microinsurance
          - if @deposit_collection.finalized?
            = link_to "#", class: 'btn', id: 'btn-approve' do
              .fa.fa-check
              Approve  
        - else
          = link_to "#", class: 'btn', id: 'btn-approve' do
            .fa.fa-check
            Approve
