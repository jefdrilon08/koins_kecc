.row
  .col
    .card
      .card-body
        - if @insurance_loan_bundle_enrollment.pending?
          = render partial: "show_pending_actions"
          .message
        - if @insurance_loan_bundle_enrollment.for_renewal?
          = render partial: "show_beneficiary"
          .message
        - if @insurance_loan_bundle_enrollment.on_grace_period?
          = render partial: "show_beneficiary"
          .message
        - if @insurance_loan_bundle_enrollment.approved?
          = render partial: "show_beneficiary"
          .message
        //for-approval
        - if @insurance_loan_bundle_enrollment.checked?
          = render partial: "show_beneficiary"
          .message
        - if @insurance_loan_bundle_enrollment.lapsed?
          = render partial: "show_beneficiary"
          .message
        - if @insurance_loan_bundle_enrollment.over_age?
          = render partial: "show_beneficiary"
          .message
        - if @insurance_loan_bundle_enrollment.declined?
          = render partial: "show_beneficiary"
          .message
        %br
        - if @records.size == 0
          %p
            No records found
        - else
          = render partial: "show_list", locals: { records: @records }
       
= render partial: "insurance_loan_bundle_enrollments/modals/approve"
= render partial: "insurance_loan_bundle_enrollments/modals/check"
= render partial: "insurance_loan_bundle_enrollments/modals/declined"
= render partial: "insurance_loan_bundle_enrollments/modals/resigned"
= render partial: "insurance_loan_bundle_enrollments/modals/matured"
= render partial: "insurance_loan_bundle_enrollments/modals/transferred"
= render partial: "insurance_loan_bundle_enrollments/modals/pending"
= render partial: "shared/errors_template"
