%table.table.table-bordered.table-sm
  %thead
    %tr
      %th
      %th
        Branch
      %th
        Center
      %th
        Member
      %th
        Enrolled Person    
      %th
        Status
  %tbody
    - @insurance_loan_bundle_enrollments.each do |o|
      %tr
        %td.text-center
          = link_to insurance_loan_bundle_enrollment_path(o) do
            .bi.bi-search
        %td
          #{o.branch}  
        %td
          #{o.center.name}
        %td
          #{o.member_name.uniq.join(",")}
        - if o.records_count > 0
          %td
            #{o.member_name.uniq.join(",")}
        - else
          %td
            #{"No record found"}
        %td
          - if o.pending?
            .badge.bg-danger
              Pending
          - if o.checked?
            .badge.bg-danger
              For Approval
          - elsif o.approved?
            .badge.bg-success
              Approved
          - elsif o.error?
            .badge.bg-danger
              ERROR
          - elsif o.processing?
            .badge.badge-info
              Processing

= paginate @insurance_loan_bundle_enrollments
