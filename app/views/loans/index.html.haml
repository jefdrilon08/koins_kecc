= title
= render partial: "shared/c_subheader", locals: { items: [{ text: "Loans" }], side_actions: [] }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            = render partial: "index_filter"
            - if @loans.any?
              = render partial: "index_list", locals: { loans: @loans }
              = paginate @loans
            - else
              %p
                No loans found
