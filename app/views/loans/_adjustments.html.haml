.row
  .col
    #btn-new-adjustment.btn.btn-primary{ data: { principal: @loan.principal, monthly_interest_rate: @loan.monthly_interest_rate, num_installments: @loan.num_installments, term: @loan.term } }
      .fa.fa-plus
      New Adjustment

%hr

- if @adjustment_records.size > 0
  %table.table.table-bordered.table-sm
    %thead
      %tr
        %th
          Date Generated
        %th
          Generated By
        %th.text-right
          Principal
        %th.text-center
          Monthly I.R.
        %th.text-center
          Num Installments
        %th.text-center
          Term
        %th
          Status
        %th
          Actions
    %tbody
      - @adjustment_records.each do |o|
        %tr
          %td
            #{o.meta["date_generated"]}
          %td
            #{o.meta["generated_by"]["last_name"]}, #{o.meta["generated_by"]["first_name"]}
          %td.text-right
            #{o.data}
