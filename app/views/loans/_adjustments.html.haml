.row
  .col
    #btn-new-adjustment.btn.btn-primary
      .fa.fa-plus
      New Adjustment

%hr

- if @adjustment_records.any?
  %table.table.table-bordered.table-sm
    %thead
      %tr
        %th
          Date Generated
        %th
          Generated By
        %th.text-right
          Principal
        %th.text-center
          Monthly I.R.
        %th.text-center
          Num Installments
        %th.text-center
          Term
        %th.text-center
          Status
        %th.text-center
          Actions
    %tbody
      - @adjustment_records.each do |o|
        %tr
          %td
            #{o.meta["date_generated"]}
          %td
            #{o.meta["generated_by"]["last_name"]}, #{o.meta["generated_by"]["first_name"]}
          %td.text-right
            #{number_to_currency(o.data["p_principal"], unit: "")}
          %td.text-center
            #{o.data["p_monthly_interest_rate"]}
          %td.text-center
            #{o.data["p_num_installments"]}
          %td.text-center
            #{o.data["p_term"]}
          %td.text-center
            - if o.pending?
              .badge.badge-danger
                Pending
            - elsif o.approved?
              .badge.badge-success
                Approved
          %td.text-center
            = link_to loan_adjustment_path(@loan, o), class: 'btn btn-primary' do
              .fa.fa-search
- else
  %p
    No adjustment records found for this loan
