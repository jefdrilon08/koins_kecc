%ol.breadcrumb
  %li.breadcrumb-item
    = link_to loans_path do
      .fa.fa-credit-card
      Loans
  %li.breadcrumb-item
    %strong
      = link_to member_path(@loan.member) do
        %span.fa.fa-user
        #{@loan.member.full_name}
      \-
      #{@loan.pn_number}
      (#{@loan.loan_product})
      \-
      - if @loan.cycle.present?
        Cycle #{@loan.cycle}
      - else
        NO LOAN CYCLE PRESENT
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      - if @loan.pending?
        #btn-approve.btn
          .fa.fa-check
          Approve
        - if !@loan.is_restructured
          = link_to loan_application_form_path(id: @loan.id, member_id: @loan.member), class: 'btn' do
            .fa.fa-pencil-alt
            Edit
        .btn#btn-delete
          .fa.fa-times
          Delete
