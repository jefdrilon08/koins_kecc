.row
  .col
    .card
      .card-body
        %center
          %label
            Loan Amount
          .text-muted
            #{number_to_currency(@loan.principal, unit: "")}
  .col
    .card
      .card-body
        %center
          %label
            Interest Amount
          .text-muted
            #{number_to_currency(@loan.interest, unit: "")}
  .col
    .card
      .card-body
        %center
          %label
            Current Balance
          .text-muted
            #{number_to_currency(@loan.total_balance, unit: "")}
  .col
    .card
      .card-body
        %center
          %label
            Total Paid
          .text-muted
            #{number_to_currency(@loan.total_paid, unit: "")}

- if @loan.restructured?
  %h5
    Restructured Loans
  %table.table.table-bordered.table-sm
    %thead
      %tr
        %th
          PN Number
        %th
          Loan Product
        %th.text-right
          Principal Balance
        %th.text-right
          Interest Balance
        %th.text-right
          Total Balance
    %tbody
      - @loan.data["restructured_loans"].each do |rl|
        %tr
          %td
            = link_to loan_path(rl.fetch("id")) do
              #{rl.fetch("pn_number")}
          %td
            #{rl["loan_product"]["name"]}
          %td.text-right
            #{number_to_currency(rl.fetch("principal_balance"), unit: "")}
          %td.text-right
            #{number_to_currency(rl.fetch("interest_balance"), unit: "")}
          %td.text-right
            #{number_to_currency(rl.fetch("total_balance"), unit: "")}

- if @loan.data["new_restructured"]
  - if @loan.loan_product_id == "1c2fcdbd-d60b-402c-b04b-824bb90958d1"
    %h5
      K-Sagip computation
    %table.table.table-bordered.table-sm
      %thead
        %tr
          %th
            PN Number
          %th
            Loan Product
          %th.text-right
            Principal Balance
          %th.text-right
            Unpaid Interest Balance
          %th.text-right
            Account Type
      %tbody
        - @loan["data"]["new_restructured"]["loan_details"].each do |h|
          %tr
            %td
              #{h["pn_number"]}
            %td
              #{h["loan_product"]["name"]}
            %td
              #{h["principal_balance"]}
            %td
              #{h["k_sagip_interest_balance"]}
            %td
              #{h["transaction_type"]}

      %table.table.table-bordered.table-sm
        %thead
          %tr
            %th Accounting Code
            %th Debit
            %th Credit
        %tbody
          %tr
            %th
              11301028 - Loans Receivables - K-SAGIP
            %td
              #{@loan["data"]["new_restructured"]["total_loanable_amount"]}
            %td
          - @loan["data"]["new_restructured"]["loan_details"].each do |h|
            %tr
              %th
                #{AccountingCode.find (Settings.loan_products.select{ |o| o[:loan_product_id] == h["loan_product"]["id"] }.last.receivable_accounting_code_id)}
              %td 
              %td
                #{h["principal_balance"]}
            %tr
              %th
                #{AccountingCode.find (Settings.loan_products.select{ |o| o[:loan_product_id] == h["loan_product"]["id"] }.last.interest_receivable_accounting_code_id)}
              %td
              %td
                #{h["k_sagip_interest_balance"]}
          - @loan["data"]["new_restructured"]["insurance_details"].each do |i|
            %tr
              %th
                #{AccountingCode.find(i["accounting_entry"]).code} - #{AccountingCode.find(i["accounting_entry"]).name}
              %td
              %td
                #{i["value"]}
          %tr
            %th
              40200000 - SERVICE FEE
            %td
            %td
              #{@loan["data"]["new_restructured"]["total_service_fee"]}
      
.row
  .col-md-4.col-xs-12

    %h4
      Details
    = render partial: "specifications"
    %hr
    %h4
      Voucher Information
    = render partial: "voucher_information"
    %hr
    %h4
      Insurance Information
    = render partial: "insurance_information"
  .col-md-8.col-xs-12
    %h4
      Amortization
    = render partial: "amortization"
