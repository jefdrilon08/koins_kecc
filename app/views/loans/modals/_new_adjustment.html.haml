#modal-new-adjustment.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          New Adjustment
      .modal-body
        .modal-body-content
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new-adjustment.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
