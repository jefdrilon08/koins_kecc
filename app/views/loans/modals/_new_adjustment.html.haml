#modal-new-adjustment.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          New Adjustment
      .modal-body
        .modal-body-content
          .row
            .col
              .form-group
                %label
                  Principal
                = number_field_tag :principal, @loan.principal, class: 'form-control', id: 'input-principal'
              .form-group
                %label
                  Monthly Interest Rate
                = number_field_tag :monthly_interest_rate, @loan.monthly_interest_rate, class: 'form-control', id: 'input-monthly-interest-rate'
              .form-group
                %label
                  Num Installments
                = number_field_tag :num_installments, @loan.num_installments, class: 'form-control', id: 'input-num-installments'
              .form-group
                %label
                  Term
                = select_tag :term, options_for_select(["weekly", "monthly"], @loan.term), class: "form-control", id: "select-term"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-new-adjustment.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
