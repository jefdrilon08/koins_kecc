#modal-change-book.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Change Books of Account
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          %label
            Book
          = select_tag :book, options_for_select(["CDB", "JVB"], @loan.data.with_indifferent_access[:accounting_entry][:book]), class: 'form-control', id: 'select-book'
          .message
      .modal-footer
        .controls
          %button#btn-confirm-change-book.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
