#modal-fruad.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Fraud Details
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          %label
            Bar Type
          = select_tag :fraud, options_for_select(Settings[:midas_type][0][:particular].map{|p| [ "#{p[:code]} - #{p[:name]}"]}), class: 'form-control', id: 'select-fraud'
          .message
          %label
            Fraud Details
          = text_area_tag :fraud_details, nil, class: 'form-control', id: 'fraud-details'
      .modal-footer
        .controls
          %button.btn{"id" => "btn-confirm", "class" => "btn-primary", "value" => "#{@loan[:id]}"}
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel