#modal-for-release.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          For Release
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
            Do you want to release this loan?
          .message
      .modal-footer
        .controls
          %button#btn-confirm-for-release.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
