#modal-delay-amort.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Delay Amortization
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          %label
            New Date for 
            %span.old-date
          = text_field_tag :new_date, "", type: "date", class: "form-control", id: "input-delay-amort"
          %hr
          %label
            Reason
          = text_field_tag :reason, "", class: "form-control", id: "input-reason"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-delay-amort.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
