#modal-reject.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Reject Loan Application
      .modal-body
        .modal-body-content
          %label
            Reason
          = text_field_tag :reason, "", class: "form-control", id: "input-rejection-reason"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-reject.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
