#modal-upload-application-form.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Upload Application Form
      .modal-body
        .modal-body-content
          = file_field_tag :application_form, id: "input-file-application-form"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-upload-application-form.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
