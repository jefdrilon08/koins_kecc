#modal-first-date-of-payment.modal.fade{:tabindex => "-1"}
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Update First Date of Payment
      .modal-body
        .modal-body-content
          .bs-callout.bs-callout-info
          %label
            First Date of Payment
          = text_field_tag :first_date_of_payment, @loan.first_date_of_payment, type: "date", class: "form-control", id: "input-first-date-of-payment"
          .message
      .modal-footer
        .controls
          %button#btn-confirm-first-date-of-payment.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
