= form_tag "", method: 'GET' do
  .row
    .col-md-3
      .form-group
        %label
          Query
        = text_field_tag :q, @q, class: 'form-control', placeholder: 'Name / ID Number'
    .col-md-2
      .form-group
        %label
          Product
        = select_tag :loan_product_id, options_from_collection_for_select(LoanProduct.order("name ASC"), :id, :name, @loan_product_id), class: "form-control select-select2", id: "loan-product-select", prompt: "-- SELECT --"
    .col-md-2
      .form-group
        %label
          Branch
        = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "branch-select", prompt: "-- SELECT --"
    .col-md-2
      .form-group
        %label
          Center
        = select_tag :center_id, options_for_select(@centers), class: "form-control select-select2", id: "center-select", prompt: "-- SELECT --"
    .col-md-2
      .form-group
        %label
          Status
        = select_tag :status, options_for_select(Loan::STATUSES, @status), class: "form-control select-select2", id: "status-select", prompt: "-- SELECT --"
    .col-md-1
      .form-group
        %label
          Actions
        = button_tag type: 'submit', class: 'btn btn-info btn-block' do
          .fa.fa-search
