%table.table.table-bordered.table-hover.table-sm
  %thead
    %tr
      %th{ rowspan: 2, colspan: 2 }
        %center
          Due Date
      %th{ colspan: 3 }
        Total Due: #{number_to_currency(@loan.total_dues, unit: "")}
      %th{ colspan: 3 }
        Total Paid: #{number_to_currency(@loan.total_paid, unit: "")}
      %th{ colspan: 3 }
        Total Balance: #{number_to_currency(@loan.total_balance, unit: "")}
    %tr
      %th.text-right
        Principal
      %th.text-right
        Interest
      %th.text-right
        Total
      %th.text-right
        Principal
      %th.text-right
        Total
      %th.text-right
        Interest
      %th.text-right
        Principal
      %th.text-right
        Interest
      %th.text-right
        Total
  %tbody
    - @amortization_schedule.each do |o|
      %tr
        %td
          %center
            - if o.is_paid
              .badge.badge-success
                .fa.fa-check
            - else
              .badge.badge-danger
                .fa.fa-times
        %td
          %center
            %strong
              #{o.due_date.strftime("%b %d, %Y")}
        %td.text-right.text-muted
          #{number_to_currency(o.principal, unit: "")}
        %td.text-right.text-muted
          #{number_to_currency(o.interest, unit: "")}
        %td.text-right
          %strong
            #{number_to_currency(o.amount_due, unit: "")}
        %td.text-right.text-muted
          #{number_to_currency(o.principal_paid, unit: "")}
        %td.text-right.text-muted
          #{number_to_currency(o.interest_paid, unit: "")}
        %td.text-right
          %strong
            #{number_to_currency(o.total_paid, unit: "")}
        %td.text-right.text-muted
          #{number_to_currency(o.principal_balance, unit: "")}
        %td.text-right.text-muted
          #{number_to_currency(o.interest_balance, unit: "")}
        %td.text-right
          %strong
            #{number_to_currency(o.total_balance, unit: "")}
    %tr
      %td
      %td
        %center
          %strong
            Total
      %td.text-right
        %strong
          #{number_to_currency(@loan.principal, unit: "")}
      %td.text-right
        %strong
          #{number_to_currency(@loan.interest, unit: "")}
      %td.text-right
        %strong
          #{number_to_currency(@loan.total_dues, unit: "")}
      %td.text-right
        %strong
          #{number_to_currency(@loan.principal_paid, unit: "")}
      %td.text-right
        %strong
          #{number_to_currency(@loan.interest_paid, unit: "")}
      %td.text-right
        %strong
          #{number_to_currency(@loan.total_paid, unit: "")}
      %td.text-right
        %strong
          #{number_to_currency(@loan.principal_balance, unit: "")}
      %td.text-right
        %strong
          #{number_to_currency(@loan.interest_balance, unit: "")}
      %td.text-right
        %strong
          #{number_to_currency(@loan.total_balance, unit: "")}
