= render partial: "show_header"

.container-fluid
  .row
    .col
      .card
        .card-body
          %ul.nav.nav-tabs{:role => "tablist"}
            %li.nav-item
              %a.nav-link.active.show{"aria-controls" => "home", "aria-selected" => "true", "data-toggle" => "tab", :href => "#details", :role => "tab"} Details
            %li.nav-item
              %a.nav-link{"aria-controls" => "loans", "aria-selected" => "false", "data-toggle" => "tab", :href => "#amortization-table", :role => "tab"} Amortization Table
            %li.nav-item
              %a.nav-link{"aria-controls" => "savings_accounts", "aria-selected" => "false", "data-toggle" => "tab", :href => "#payments-table", :role => "tab"} Payments
          .tab-content
            #details.tab-pane.active.show{:role => "tabpanel"}
              = render partial: "details"
            #amortization-table.tab-pane{:role => "tabpanel"}
              = render partial: "amortization_table"
            #payments-table.tab-pane{:role => "tabpanel"}
              = render partial: "transaction_table"

= render partial: "loans/modals/reage"
= render partial: "templates/error_list"

= javascript_include_tag "loans/Show.js"

#parameters{ data: { id: @loan.id } }

:javascript
  $(document).ready(function() {
    var authenticityToken = $("meta[name='csrf-token']").attr('content');
    var loanId  = $("#parameters").data('id');

    Show.init({
      loanId: loanId,
      authenticityToken: authenticityToken
    });
  });
