.table-responsive
  %table.table.table-sm.table-hover
    %thead
      %tr
        %th.text-center
          %span
        %th{ width: "25%" }
          Member
        %th
          Type
        %th
          Branch / Center
        %th
          %center
            Maturity Date
        %th.text-end
          Amount
        %th.text-end
          Balance
        %th
          %center
            Status
    %tbody
      - @loans.each do |loan|
        %tr
          %td.text-center
            %strong
              = link_to loan_path(loan.id), target: '_blank' do
                .bi.bi-search
          %td
            %strong
              #{loan.data.fetch("member_full_name", nil)}
          %td
            %small
              %strong
                - if loan.is_remote?
                  .bi.bi-globe
                #{loan.data.fetch("loan_product_name", nil)}
          %td
            %small
              #{loan.data.fetch("branch_name", nil)} / #{loan.data.fetch("center_name", nil)}
          %td
            - if loan.active_or_paid?
              %center
                %small
                  - if loan.maturity_date.present?
                    #{loan.maturity_date.strftime("%b %d, %Y")}
          %td.text-end
            %strong
              #{number_to_currency(loan.total_dues, unit: "")}
          %td.text-end
            .text-muted
              #{number_to_currency(loan.total_balance, unit: "")}
          %td
            %center
              - if loan.pending?
                .badge.bg-danger
                  #{loan.status}
              - else
                .badge.bg-success
                  #{loan.status}
