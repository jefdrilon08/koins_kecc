.table-responsive
  %table.table.table-sm.table-hover
    %thead
      %tr
        %th{ width: "25%" }
          Member
        %th
          Type
        %th
          Branch / Center
        %th
          %center
            Maturity Date
        %th.text-end
          Amount
        %th.text-end
          Balance
        %th
          %center
            Status
    %tbody
      - @loans.each do |loan|
        %tr
          %td
            %strong
              = link_to loan_path(loan.id), target: '_blank' do
                #{loan.member.full_name}
          %td
            %small
              %strong
                - if loan.is_remote?
                  .fa.fa-globe-asia
                #{loan.loan_product}
          %td
            %small
              #{loan.branch.name} / #{loan.center.name}
          %td
            - if loan.active_or_paid?
              %center
                %small
                  - if loan.maturity_date.present?
                    #{loan.maturity_date.strftime("%b %d, %Y")}
          %td.text-end
            %strong
              #{number_to_currency(loan.total_dues, unit: "")}
          %td.text-end
            .text-muted
              #{number_to_currency(loan.total_balance, unit: "")}
          %td
            %center
              - if loan.pending?
                .badge.bg-danger
                  #{loan.status}
              - else
                .badge.bg-success
                  #{loan.status}
