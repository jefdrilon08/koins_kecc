= title @equity_account.id
.row
  .col
    .card
      .card-body
        %table.table.table-hover.table-sm
          %thead
            %tr
              %th
                %center
                  Date
              %th
                %center
                  Type
              %th.text-end
                Beginning Balance
              %th.text-end
                Amount
              %th.text-end
                Ending Balance
          %tbody
            - @account_transactions.each do |o|
              %tr
                %td
                  %center
                    #{o.transacted_at.strftime("%b %d, %Y")}
                %td
                  %center
                    #{o.transaction_type}
                %td.text-end.text-muted
                  #{number_to_currency(o.data["beginning_balance"], unit: "")}
                %td.text-end
                  #{number_to_currency(o.amount, unit: "")}
                %td.text-end.text-muted
                  #{number_to_currency(o.data["ending_balance"], unit: "")}
