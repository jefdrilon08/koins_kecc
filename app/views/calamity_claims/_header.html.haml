%ol.breadcrumb
  %li.breadcrumb-item
    .fa.fa-money-check
      Calamity Assistance
  %li.breadcrumb-item
    .fa.fa-user
    = link_to "#{@calamity_claim.member.full_name}", member_path(@calamity_claim.member), target: "_blank"
  %li.breadcrumb-menu.d-md-down-none
    .btn-group
      = link_to edit_member_calamity_claim_path(@calamity_claim.member, @calamity_claim), class: 'btn btn-app' do
        %i.fa.fa-edit
        Edit
    .btn-group 
      = link_to calamity_claim_path(@calamity_claim), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-app" do
        %i.fa.fa-times
        Delete
    .btn-group    
      = link_to calamity_claim_calamity_claim_validation_pdf_path(@calamity_claim), target: "_blank", class: "btn btn-app" do
        .fa.fa-download
        Validation PDF
    .btn-group 
      = link_to calamity_claim_calamity_claim_loa_pdf_path(@calamity_claim), target: "_blank", class: "btn btn-app" do
        .fa.fa-print
        LOA
    .btn-group
      = link_to calamity_claims_path do
        .fa.fa-arrow-left
        Back to Claims