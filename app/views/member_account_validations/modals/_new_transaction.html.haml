#modal-new-transaction.modal.fade
  .modal-dialog.modal-lg
    .modal-content
      .modal-header
        %h3.modal-title
          New Transaction
      .modal-body
        .modal-body-content
          .row
            .col-md-8
              .form-group
                %label
                  Branch
                = select_tag :branch_id, options_from_collection_for_select(@branches, :id, :name, @branch.try(:id)), class: "form-control select-select2", id: "select-branch", prompt: "-- SELECT --"
            .col-md-4
              .form-group
                %label
                  Collection Date
                = text_field_tag :date_prepared, Date.today, type: 'date', id: 'input-collection-date', class: 'form-control'
          .message
      .modal-footer
        .controls
          %button#btn-generate-insurance-account-validation.btn.btn-primary
            .fa.fa-check
            Confirm
          %button.btn{"data-bs-dismiss" => "modal", :type => "button"}
            .fa.fa-times
            Cancel
