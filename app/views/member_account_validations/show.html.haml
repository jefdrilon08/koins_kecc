= title @member_account_validation.id
= render partial: "shared/c_subheader", locals: { items: @subheader_items, side_actions: @subheader_side_actions }

%main.c-main
  .container-fluid
    .row
      .col
        .card
          .card-body
            - if @member_account_validation.for_validation?
              .bs-callout.bs-callout-danger
                %h3
                  .fa.fa-warning
                  This has already been checked by #{@member_account_validation.checked_by} on #{@member_account_validation.date_checked}"
              %hr
            - if @member_account_validation.for_approval?
              .bs-callout.bs-callout-danger
                %h3
                  .fa.fa-warning
                  This has already been validated by #{@member_account_validation.validated_by} on #{@member_account_validation.date_validated}"      
              %hr
            - if @member_account_validation.cancelled?
              .bs-callout.bs-callout-danger
                %h3
                  .fa.fa-warning
                  This has been cancelled by #{@member_account_validation.cancelled_by} on #{@member_account_validation.date_cancelled}"      
              %hr
            - if @member_account_validation.reversed?
              .bs-callout.bs-callout-danger
                %h3
                  .fa.fa-warning
                  Warning: This transaction has been reversed.
            = render partial: "actions", locals: { member_account_validation: @member_account_validation, role: @role }
            = render partial: "member_account_validation_records", locals: { member_account_validation: @member_account_validation }
            - if @member_account_validation.member_account_validation_cancellations.count > 0
              = render partial: "member_account_validation_cancellations", locals: { member_account_validation: @member_account_validation }
            - if !@member_account_validation.data.nil?
              = render partial: "shared/accounting_entry_hash", locals: { accounting_entry: @accounting_entry_data } 

= render partial: "member_account_validations/modals/approve"
= render partial: "member_account_validations/modals/validate"
= render partial: "member_account_validations/modals/check"
= render partial: "member_account_validations/modals/cancel"
