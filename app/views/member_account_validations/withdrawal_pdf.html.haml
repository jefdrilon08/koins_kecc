:css
  .print-text {
    font-size: .9em;
    font-family: arial;
  }


  .print-text-sub {
    font-size: .9em;
    font-family: arial;
  }

  table {
    border-collapse: collapse;
  }

  table, th, td {
    border: 1.5px solid black;
  }

  hr {
    border-color: black;
  }

  .content{
    height: 90px;
    width: 100%;
    float: left;
    padding: 15px 20px 20px 40px;
  }

%span.print-text
  %br
  %br
  %br
  %br
