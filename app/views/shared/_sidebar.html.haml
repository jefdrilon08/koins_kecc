.sidebar.close
  = link_to root_path do
    .logo-details
      %i.bi.bi-house-door
      %span.logo-name
        KOINS
  %ul.nav-links
    %li{ class: "#{params[:controller] == 'pages' and params[:action] == 'index' ? 'active' : ''}" }
      = link_to root_path, class: "" do
        %i.bi.bi-speedometer
        %span.link-name
          Operations

    %li{ class: "#{params[:controller] == 'members' ? 'active' : ''}" }
      .icon-link
        = link_to members_path, class: "" do
          %i.bi.bi-person-square
          %span.link-name
            Members
        %i.bi.bi-caret-down.arrow
      %ul.sub-menu
        %li
          = link_to members_path, class: "link-name" do
            Members
        %li
          = link_to member_form_path, class: "" do
            %i.bi.bi-plus
            New Member
        %li
          = link_to members_path(status: "pending"), class: "" do
            %i.bi.bi-exclamation
            Pending Members

    - if microloans?
      %li{ class: "#{params[:controller] == 'loans' ? 'active' : ''}" }
        .icon-link
          = link_to loans_path, class: "" do
            %i.bi.bi-credit-card
            %span.link-name
              Loans
          %i.bi.bi-caret-down.arrow
        %ul.sub-menu
          %li
            = link_to loans_path, class: "link-name" do
              Loans
          %li
            = link_to loans_path(status: "pending"), class: "" do
              %i.bi.bi-exclamation
              Pending
            = link_to loans_path(status: "for-verification"), class: "" do
              %i.bi.bi-folder-check
              For Verification
            = link_to loans_path(status: "for-release"), class: "" do
              %i.bi.bi-bag-check
              For Release
            = link_to loans_path(status: "active"), class: "" do
              %i.bi.bi-bookmark-check
              Active
            
