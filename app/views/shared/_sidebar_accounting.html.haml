        %li{ class: "nav-item #{params[:controller] == 'patronage_refund' ? 'active' : ''}" }
          = link_to "/data_stores/patronage_refund", class: 'nav-link' do
            %i.nav-icon.fa.fa-database
            Patronage Refund
      %li{ class: "nav-item nav-dropdown" }
        = link_to "#", class: "nav-link nav-dropdown-toggle" do
          %i.nav-icon.fa.fa-book-reader
