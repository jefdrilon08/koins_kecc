      %li.nav-title
        Reports
      %li{ class: "nav-item #{params[:controller] == 'accounting/accounting_codes' ? 'active' : ''}" }
        = link_to accounting_year_end_closings_path, class: 'nav-link' do
          %i.nav-icon.fa.fa-file
          Year End Closing
      - if microloans?    
        %li{ class: "nav-item #{params[:controller] == 'icpr' ? 'active' : ''}" }
          = link_to "/data_stores/icpr", class: 'nav-link' do
            %i.nav-icon.fa.fa-database
