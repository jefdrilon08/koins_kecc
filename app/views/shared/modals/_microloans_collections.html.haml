#modal-nav-microloans-collections.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Collection Modules
      .modal-body
        = link_to billings_path(status: "pending"), class: "btn btn-primary w-100 mt-4" do
          %span.btn-label
            %i.bi.bi-receipt
          Billings
        = link_to billing_for_full_payments_path, class: "btn btn-primary w-100 mt-4" do
          %span.btn-label
            %i.bi.bi-receipt
          Billings for Full Payment
        = link_to accrued_payment_collections_path, class: "btn btn-primary w-100 mt-4" do
          %span.btn-label
            %i.bi.bi-receipt
          Accrued Interest Billing
        = link_to membership_payment_collections_path, class: "btn btn-primary w-100 mt-4" do
          %span.btn-label
            %i.bi.bi-receipt
          Membership Payments
        = link_to time_deposit_collections_path, class: "btn btn-primary w-100 mt-4" do
          %span.btn-label
            %i.bi.bi-receipt
          Time Deposits
