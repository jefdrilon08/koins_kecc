#modal-nav-microloans-collections.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Collection Modules
      .modal-body
        .row
          .col
            = link_to billings_path(status: "pending"), class: "btn-nav-square-md" do
              Billings
        .mt-4
        .row
          .col
            = link_to billing_for_full_payments_path, class: "btn-nav-square-md" do
              Full Payment
        .mt-4
        .row
          .col
            = link_to accrued_payment_collections_path, class: "btn-nav-square-md" do
              Accrued Interest
        .mt-4
        .row
          .col
            = link_to membership_payment_collections_path, class: "btn-nav-square-md" do
              Membership Payments
        .mt-4
        .row
          .col
            = link_to time_deposit_collections_path, class: "btn-nav-square-md" do
              Time Deposits
