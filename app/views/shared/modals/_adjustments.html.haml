#modal-nav-adjustments.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title 
          Adjustments
      .modal-body
        = link_to adjustments_subsidiary_adjustments_path, class: "btn btn-primary w-100" do
          %span.btn-label
            %i.bi.bi-wrench-adjustable
          Subsidiary
        - if microloans?
          = link_to adjustments_batch_moratorium_adjustments_path, class: "btn btn-primary w-100 mt-4" do
            %span.btn-label
              %i.bi.bi-wrench-adjustable
            Batch Moratorium
