#modal-nav-monthly-transactions.modal.fade
  .modal-dialog
    .modal-content
      .modal-header
        %h3.modal-title
          Collection Modules
      .modal-body
        = link_to monthly_closing_collections_path, class: "btn btn-primary w-100" do
          %span.btn-label
            %i.bi.bi-calendar-event
          Monthly Transacions
        = link_to insurance_monthly_closing_collections_path, class: "btn btn-primary w-100 mt-4" do
          %span.btn-label
            %i.bi.bi-calendar-event
          Insurance Monthly Closing
        = link_to "data_stores/monthly_incentives", class: "btn btn-primary w-100 mt-4" do
          %span.btn-label
            %i.bi.bi-calendar-event
          Monthly Incentives
