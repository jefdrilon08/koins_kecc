#modal-nav-admin.modal.fade
  .modal-dialog.modal-xl
    .modal-content
      .modal-header
        %h3.modal-title 
          Administration
      .modal-body
        .row
          - if sbk_mis_bk?
            .col
              = link_to accounting_accounting_codes_path, class: "btn-nav-square-md" do
                Chart of Accounts
          .mt-4
          .row
            .col
              = link_to administration_users_path, class: "btn-nav-square-md" do
                Users
            .col
              = link_to administration_loan_product_categories_path, class: "btn-nav-square-md" do
                Loan Product Categories
            .col
              = link_to administration_loan_products_path, class: "btn-nav-square-md" do
                Loan Products
        .mt-4
        .row
          - if is_mis_user?
            .col
              = link_to administration_areas_path, class: "btn-nav-square-md" do
                Areas
            .col
              = link_to administration_clusters_path, class: "btn-nav-square-md" do
                Clusters
          
          .col
            = link_to administration_branches_path, class: "btn-nav-square-md" do
              Branches
          
          .col
            = link_to administration_centers_path, class: "btn-nav-square-md" do
              Centers
        .mt-4
        .row
          .col
            = link_to administration_membership_arrangements_path, class: "btn-nav-square-md" do
              Membership Arrangements
          .col
            = link_to administration_membership_types_path, class: "btn-nav-square-md" do
              Membership Types
        .mt-4
        .row
          .col
            = link_to administration_surveys_path, class: "btn-nav-square-md" do
              Surveys
          .col
            = link_to administration_project_type_categories_path, class: "btn-nav-square-md" do
              Project Type Categories
          .col
            = link_to administration_announcements_path, class: "btn-nav-square-md" do
              Announcements
          .col
            = link_to administration_referrers_path, class: "btn-nav-square-md" do
              Referrers
          .col
            = link_to "/bank_transfer", class:"btn-nav-square-md" do
              Bank Transfer
          .mt-4
          .row
            - if is_mis_user?
              .col
                = link_to "/administration/admin_address", class: "btn-nav-square-md" do
                  Region
              .col 
                = link_to "/administration/admin_province", class: "btn-nav-square-md" do
                  Province
              .col 
                = link_to "/administration/admin_municipality", class: "btn-nav-square-md" do
                  Municipality
              .col 
                = link_to "/administration/admin_barangay", class: "btn-nav-square-md" do
                  Barangay
            

