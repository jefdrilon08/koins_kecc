%li{ class: "#{SIDEBAR_TRANSACTIONS_CONTROLLERS.include?(params[:controller]) ? 'active' : ''}" }
  .icon-link
    = link_to "#", class: "" do
      %i.bi.bi-cast
      %span.link-name
        Transactions
    %i.bi.bi-caret-down.arrow
  %ul.sub-menu
    %li
      = link_to "#", class: "link-name" do
        Transactions
    - if microloans?
      %li
        = link_to "#", class: "", data: { "bs-toggle": "modal", "bs-target": "#modal-nav-microloans-collections" } do
          %i.bi.bi-receipt
          Collections
      %li
        = link_to time_deposit_collections_path, class: "" do
          %i.bi.bi-receipt
          Time Deposits
    %li
      = link_to deposit_collections_path, class: "" do
        %i.bi.bi-receipt
        Deposits
    %li
      = link_to withdrawal_collections_path, class: "" do
        %i.bi.bi-receipt
        Withdrawals
    %li
      = link_to "#", class: "", data: { "bs-toggle": "modal", "bs-target": "#modal-nav-new-entry" } do
        %i.bi.bi-plus-circle
        New Entry
    %li
      = link_to "#", class: "", data: { "bs-toggle": "modal", "bs-target": "#modal-nav-interest" } do
        %i.bi.bi-calculator
        Interest

    - if microinsurance?
      %li
        = link_to insurance_fund_transfer_collections_path, class: "" do
          %i.bi.bi-exclamation-circle
          Insurance Fund Transfer
